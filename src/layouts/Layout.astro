---
interface Props {
  title?: string;
  showBack?: boolean;
}
import "../styles/global.css";
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import ThemeSwitcher from "../components/ThemeSwitcher.astro";
import BackButton from "../components/BackButton.astro";
import { ClientRouter } from "astro:transitions";
const { title = "Akif Zahin", showBack = false } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="I build AI-powered apps, full-stack tools, and solutions for real-world problems. Based in Dhaka, Bangladesh. Open to freelance and collaborations."
    />
    <meta name="author" content="Akif Zahin" />
    <meta
      property="og:title"
      content="Akif Zahin — Full-stack Developer & AI Builder in Dhaka"
    />
    <meta
      property="og:description"
      content="I build AI-powered apps, full-stack tools, and solutions for real-world problems. Based in Dhaka, Bangladesh. Open to freelance and collaborations."
    />
    <meta property="og:image" content="https://akifzahin.dev/og.png" />
    <meta property="og:url" content="https://akifzahin.dev" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:title"
      content="Akif Zahin — Full-stack Developer & AI Builder in Dhaka"
    />
    <meta
      name="twitter:description"
      content="I build AI-powered apps, full-stack tools, and solutions for real-world problems. Based in Dhaka, Bangladesh. Open to freelance and collaborations."
    />
    <meta name="twitter:image" content="https://akifzahin.dev/og.png" />
    <link rel="canonical" href="https://akifzahin.dev" />
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        name: "Akif Zahin",
        url: "https://akifzahin.dev",
        jobTitle: "Full-stack Developer",
        address: {
          "@type": "PostalAddress",
          addressLocality: "Dhaka",
          addressCountry: "BD",
        },
        sameAs: [
          "https://github.com/akifzahin",
          "https://linkedin.com/in/akifzahin",
          "https://medium.com/@akifzahin",
        ],
      })}
    />

    <!-- ClientRouter: enables SPA navigation -->
    <ClientRouter />

    <!--
      Theme flash prevention: must be inline + in <head> so it runs
      before the first paint on every hard load and SPA navigation.
    -->
    <script is:inline>
      (function () {
        var p = localStorage.getItem("theme-primary");
        var a = localStorage.getItem("theme-accent");
        var dark = localStorage.getItem("theme-dark");
        if (p && a) {
          var toRgb = function (hex) {
            return [1, 3, 5]
              .map(function (o) {
                return parseInt(hex.slice(o, o + 2), 16);
              })
              .join(", ");
          };
          var root = document.documentElement;
          root.style.setProperty("--primary", p);
          root.style.setProperty("--accent", a);
          root.style.setProperty("--primary-rgb", toRgb(p));
          root.style.setProperty("--accent-rgb", toRgb(a));
          root.style.setProperty(
            "--primary-dim",
            "rgba(" + toRgb(p) + ", 0.1)",
          );
          root.style.setProperty(
            "--primary-glow",
            "rgba(" + toRgb(p) + ", 0.4)",
          );
          root.style.setProperty("--accent-dim", "rgba(" + toRgb(a) + ", 0.1)");
          root.style.setProperty(
            "--accent-glow",
            "rgba(" + toRgb(a) + ", 0.4)",
          );
        }
        if (dark === "false") document.documentElement.classList.add("light");
      })();
    </script>

    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Share+Tech+Mono&family=Inter:wght@300;400&display=swap"
      rel="stylesheet"
    />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css"
    />
    <!-- Three.js (required by most Vanta effects) -->
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js"></script>
    <!-- p5.js (required specifically by Vanta TRUNK and TOPOLOGY) -->
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.1.9/p5.min.js"></script>
    <!-- Vanta effects -->
    <script is:inline src="https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.net.min.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.waves.min.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.fog.min.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.cells.min.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.topology.min.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.birds.min.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.dots.min.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.globe.min.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.halo.min.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.rings.min.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.ripple.min.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.trunk.min.js"></script>
  </head>
  <body>
    <!-- Vanta.js mount target — sits behind CSS grid via z-index -->
    <div id="vanta-bg"></div>
    <div class="nav-wrapper">
      <nav>
        <div class="nav-left">
          <a href="/" class="logo font-display">
            <span class="logo-a">A</span><span class="logo-z">Z</span>
          </a>
          {showBack && <BackButton />}
          <ThemeSwitcher />
        </div>
        <ul class="nav-links">
          <li><a href="/#work">Work</a></li>
          <li><a href="/#skills">Skills</a></li>
          <li><a href="/#experience">Experience</a></li>
          <li><a href="/#about">About</a></li>
          <li><a href="/#contact">Contact</a></li>
          <li><a href="/blog">Blog</a></li>
        </ul>
        <button
          class="nav-hamburger"
          id="nav-hamburger"
          aria-label="Toggle menu"
        >
          <span></span><span></span><span></span>
        </button>
      </nav>
      <div class="nav-drawer" id="nav-drawer">
        <ul>
          <li><a href="/#work">Work</a></li>
          <li><a href="/#skills">Skills</a></li>
          <li><a href="/#experience">Experience</a></li>
          <li><a href="/#about">About</a></li>
          <li><a href="/#contact">Contact</a></li>
          <li><a href="/blog" data-astro-prefetch>Blog</a></li>
        </ul>
      </div>
    </div>

    <slot />

    <Analytics />
    <SpeedInsights />
  </body><!-- ── All persistent UI — recreated on every page-load ──────────────── --><!--
    The body is fully swapped on each SPA navigation, so any elements
    appended to document.body are wiped. We recreate them all inside
    astro:page-load, which fires on hard load AND after every navigation.
    Window-level listeners (mousemove, scroll, mousedown) are registered
    once via a flag on window so they don't stack across navigations.
  -->
  <script>
    // ── Vanta background system ─────────────────────────────────────────────
  let vantaInstance: any = null;

  function hexToNum(hex: string): number {
    return parseInt(hex.replace('#', ''), 16);
  }

  // ── Matrix rain (custom canvas effect for Webcore) ──────────────────────
  // Not a Vanta effect — Vanta has no matrix-rain preset, so this is a
  // hand-rolled canvas animation that plugs into the exact same
  // init/destroy/theme-change lifecycle as the Vanta effects below.
  let matrixRafId: number | null = null;
  let matrixAlive = false;
  let matrixResizeHandler: (() => void) | null = null;

  function hexToTriplet(hex: string): [number, number, number] {
    const clean = hex.replace('#', '');
    return [
      parseInt(clean.slice(0, 2), 16),
      parseInt(clean.slice(2, 4), 16),
      parseInt(clean.slice(4, 6), 16),
    ];
  }

  function stopMatrixRain() {
    matrixAlive = false;
    if (matrixRafId !== null) {
      cancelAnimationFrame(matrixRafId);
      matrixRafId = null;
    }
    if (matrixResizeHandler) {
      window.removeEventListener('resize', matrixResizeHandler);
      matrixResizeHandler = null;
    }
    document.getElementById('matrix-rain-canvas')?.remove();
  }

  function startMatrixRain(primaryHex: string, accentHex: string) {
    stopMatrixRain(); // safety: never double-mount

    const mount = document.getElementById('vanta-bg');
    if (!mount) return;

    const canvas = document.createElement('canvas');
    canvas.id = 'matrix-rain-canvas';
    canvas.style.cssText = 'position:absolute; inset:0; width:100%; height:100%; display:block;';
    mount.appendChild(canvas);

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const inc = 26;
    let width = 0, height = 0, cols = 0, rows = 0;
    let streaks: Streak[] = [];

    const [pr, pg, pb] = hexToTriplet(primaryHex);
    const [ar, ag, ab] = hexToTriplet(accentHex);

    function randomChar(): string {
      const r = Math.random();
      if (r < 0.6) return String.fromCharCode(0x30a0 + Math.round(Math.random() * 96));
      if (r < 0.9) return String.fromCharCode(0x50d0 + Math.round(Math.random() * 222));
      return String(Math.round(Math.random() * 9));
    }

    class Cell {
      x: number; y: number; l: number; tip: boolean; b: number; val: string;
      constructor(x: number, y: number, l: number, tip: boolean) {
        this.x = x; this.y = y; this.l = l; this.tip = tip;
        this.b = 55;
        this.val = randomChar();
      }
      update() {
        if (this.b > 55) {
          if (Math.random() < 0.1) this.val = randomChar();
          this.b -= this.l;
        } else this.b = 55;
      }
      show() {
        const frac = Math.max(0, Math.min(1, this.b / 255));
        if (this.tip && this.b === 255) {
          ctx!.fillStyle = `rgb(${ar}, ${ag}, ${ab})`;
        } else {
          ctx!.fillStyle = `rgba(${pr}, ${pg}, ${pb}, ${frac})`;
        }
        ctx!.fillText(this.val, this.x, this.y);
      }
    }

    class Streak {
      t: Cell[] = [];
      del: number; time = 0; done = false; interval: number; count = 0;
constructor(xIndex: number) {
  // Slows down brightness decay so characters stay lit longer
  const l = Math.random() * 20 + 15; 
  
  const tip = Math.random() < 0.4;
  for (let i = 0; i < rows; i++) {
    this.t[i] = new Cell(xIndex * inc + inc / 2, i * inc + inc, l, tip);
  }
  
  this.del = Math.random() * 140 + 10;
  
  // Increases frames between steps so the streak falls slower
  this.interval = Math.round(Math.random() * 3 + 4); 
}
      run() {
        if (!this.done) {
          if (this.time < this.del) this.time++;
          else { this.t[0].b = 255; this.done = true; }
        }
        for (let i = rows - 1; i >= 0; i--) this.t[i].show();
        this.count++;
        if (this.count > this.interval) {
          this.count = 0;
          for (let i = rows - 1; i >= 0; i--) {
            if (this.t[i].b === 255) {
              if (i < rows - 1) this.t[i + 1].b = 255;
              else this.t[0].b = 255;
            }
            this.t[i].update();
          }
        }
      }
    }

    function build() {
      width = canvas.width = mount!.clientWidth;
      height = canvas.height = mount!.clientHeight;
      cols = Math.ceil(width / inc);
      rows = Math.ceil(height / inc);
      ctx!.font = `${inc}px monospace`;
      ctx!.textAlign = 'center';
      streaks = [];
      for (let i = 0; i < cols; i++) streaks[i] = new Streak(i);
    }

    build();

    matrixAlive = true;
    function frame() {
      if (!matrixAlive) return;
      ctx!.clearRect(0, 0, width, height);
      for (let i = 0; i < cols; i++) streaks[i].run();
      matrixRafId = requestAnimationFrame(frame);
    }
    frame();

    matrixResizeHandler = () => build();
    window.addEventListener('resize', matrixResizeHandler);
  }

function getVantaConfig(themeName: string, primary: string, accent: string): { effect: string; options: Record<string, any> } | null {
  const isDark = !document.documentElement.classList.contains('light');
  const bg = isDark ? 0x0a0a0a : 0xd7d7d7;

  // Swap which color leads based on mode — matches the rest of the site,
  // where light mode promotes --accent and dark mode keeps --primary.
  const primaryHex = isDark ? primary : accent;
  const accentHex  = isDark ? accent : primary;
  const p = hexToNum(primaryHex);
  const a = hexToNum(accentHex);

  const base = { el: '#vanta-bg', THREE: (window as any).THREE, mouseControls: true, touchControls: true, gyroControls: false };

  switch (themeName) {
    case 'Cyberpunk':
      return null;

    case 'Webcore':
      // Custom matrix-rain canvas, not a Vanta preset — handled specially in initVanta.
      return { effect: 'MATRIX', options: { primaryHex, accentHex } };

    case 'Retro Futurism':
      return { effect: 'TOPOLOGY', options: { ...base, color: p, backgroundColor: bg, minHeight: 200.00, minWidth: 200.00, scale: 1.00, scaleMobile: 1.00 } };

    case 'Mythic Fiction':
      return { effect: 'FOG', options: { ...base, highlightColor: p, midtoneColor: a, lowlightColor: 0x0a0005, baseColor: bg, blurFactor: 0.6, speed: 1.2, zoom: 0.9 } };

    case 'Dreamcore':
      return { effect: 'CELLS', options: { ...base, color1: p, color2: a, backgroundColor: bg, size: 2.5, speed: 1.2 } };

  case 'Cassette Futurism':
    return { 
      effect: 'TRUNK', 
      options: { 
        ...base, 
        color: p, 
        backgroundColor: bg, 
        minHeight: 200.00, 
        minWidth: 200.00, 
        // ── The Performance Fixes ──────────────────────────────────────
        scale: 2.00,        // Scales up the coordinate grid (fewer calculations)
        scaleMobile: 3.00,  // Scale up even more on mobile to save the GPU
        spacing: 20.00,     // Doubled spacing = roughly half the lines to draw
        chaos: 0.30         // Lower chaos reduces complex directional changes
      } 
    };

      default:
        return null;
    }
  }

  function destroyVanta() {
    if (vantaInstance) {
      try { vantaInstance.destroy(); } catch (_) {}
      vantaInstance = null;
    }
    stopMatrixRain();
    // Vanta's destroy() doesn't always strip its own <canvas> out of the
    // container on every version — force-clear so a leftover canvas from
    // the previous effect can never sit on top of whatever comes next.
    const mount = document.getElementById('vanta-bg');
    if (mount) mount.innerHTML = '';
    document.body.classList.remove('has-vanta');
  }

  function initVanta(themeName: string, primary: string, accent: string) {
    destroyVanta();

    const config = getVantaConfig(themeName, primary, accent);

    // Cyberpunk or unknown theme with no config → CSS grid stays, no effect
    if (!config) return;

    // Matrix rain is a hand-rolled canvas effect, not Vanta — short-circuit here.
    if (config.effect === 'MATRIX') {
      startMatrixRain(config.options.primaryHex, config.options.accentHex);
      document.body.classList.add('has-vanta');
      return;
    }

    const VANTA = (window as any).VANTA;

    // Fallback: if Vanta hasn't loaded yet or effect missing, CSS grid takes over
    if (!VANTA) {
      console.warn('[vanta] VANTA not loaded — CSS grid fallback active');
      return;
    }

    const effectFn = VANTA[config.effect];
    if (!effectFn) {
      console.warn(`[vanta] Effect VANTA.${config.effect} not found — CSS grid fallback active`);
      return;
    }

    try {
      vantaInstance = effectFn(config.options);
      document.body.classList.add('has-vanta');
    } catch (err) {
      console.warn('[vanta] Failed to init effect — CSS grid fallback active', err);
      destroyVanta();
    }
  }

  function initVantaFromStorage() {
    const themeName = localStorage.getItem('theme-name') ?? 'Cyberpunk';
    const primary   = localStorage.getItem('theme-primary') ?? '#0fd28c';
    const accent    = localStorage.getItem('theme-accent')  ?? '#f40bf4';
    initVanta(themeName, primary, accent);
  }

  function initPersistentUI() {
      // ── Vanta boot ──────────────────────────────────────────────────────
      initVantaFromStorage();

      // Re-register theme-change listener each page load (body is swapped by SPA)
      document.addEventListener('theme-change', (e: Event) => {
        const { name, primary, accent } = (e as CustomEvent).detail;
        initVanta(name, primary, accent);
      });

      // Tear down before SPA swap (once per page)
      document.addEventListener('astro:before-swap', destroyVanta, { once: true });

      // ── Hamburger / drawer ──────────────────────────────────────────────
      const hamburger = document.getElementById("nav-hamburger");
      const drawer = document.getElementById("nav-drawer");
      hamburger?.addEventListener("click", () => {
        hamburger.classList.toggle("open");
        drawer?.classList.toggle("open");
      });
      drawer?.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => {
          hamburger?.classList.remove("open");
          drawer?.classList.remove("open");
        });
      });

    // ── Cursor + trail ──────────────────────────────────────────────────
    const isOn = false; // Set to false to turn off custom cursor, true to turn it on

    if (!isOn) {
      // Remove the class so the default cursor shows up
      document.body.classList.remove("has-custom-cursor");
    } else if (!window.matchMedia("(hover: none) and (pointer: coarse)").matches) {
      // Add the class so the CSS hides the default cursor
      document.body.classList.add("has-custom-cursor");

      const cursorBlob = document.createElement("div");
      cursorBlob.id = "cursor-blob";
      const cursorDot = document.createElement("div");
      cursorDot.id = "cursor-dot";

      cursorBlob.style.cssText = "position:fixed; top:0; left:0; will-change:transform; pointer-events:none; z-index:99998;";
      cursorDot.style.cssText = "position:fixed; top:0; left:0; will-change:transform; pointer-events:none; z-index:99999;";

      document.body.appendChild(cursorBlob);
      document.body.appendChild(cursorDot);

      const TRAIL_COUNT = 8;
      const LERP_BLOB = 0.1;
      const LERP_TRAIL = 0.3;

      const rootStyles = getComputedStyle(document.documentElement);
      const primaryColor = rootStyles.getPropertyValue("--primary").trim();
      const accentColor = rootStyles.getPropertyValue("--accent").trim();

      const trail = Array.from({ length: TRAIL_COUNT }, (_, i) => {
        const el = document.createElement("div");
        const size = Math.max(1, 5 - i * 0.5);
        const color = i < TRAIL_COUNT / 2 ? primaryColor : accentColor;
        
        el.style.cssText = `position:fixed;top:0;left:0;pointer-events:none;z-index:99997;border-radius:50%;width:${size}px;height:${size}px;margin-left:-${size / 2}px;margin-top:-${size / 2}px;opacity:${(1 - i / TRAIL_COUNT).toFixed(2)};background:${color};will-change:transform;`;
        document.body.appendChild(el);
        
        return { el, x: 0, y: 0 };
      });

      let mx = 0, my = 0, bx = 0, by = 0;
      let alive = true;

      const onMove = (e) => {
        mx = e.clientX;
        my = e.clientY;
      };

      window.addEventListener("mousemove", onMove, { passive: true });

      document.querySelectorAll("a, button, [data-hover]").forEach((el) => {
        el.addEventListener("mouseenter", () => {
          cursorBlob.classList.add("cursor-hover");
          cursorDot.classList.add("cursor-hover");
        });
        el.addEventListener("mouseleave", () => {
          cursorBlob.classList.remove("cursor-hover");
          cursorDot.classList.remove("cursor-hover");
        });
      });

      (function tick() {
        if (!alive) return;
        
        bx += (mx - bx) * LERP_BLOB;
        by += (my - by) * LERP_BLOB;

        trail[0].x += (mx - trail[0].x) * LERP_TRAIL;
        trail[0].y += (my - trail[0].y) * LERP_TRAIL;
        for (let i = 1; i < TRAIL_COUNT; i++) {
          trail[i].x += (trail[i - 1].x - trail[i].x) * LERP_TRAIL;
          trail[i].y += (trail[i - 1].y - trail[i].y) * LERP_TRAIL;
        }

        cursorDot.style.transform = `translate3d(${mx}px, ${my}px, 0)`;
        cursorBlob.style.transform = `translate3d(${bx}px, ${by}px, 0)`;

        for (let i = 0; i < TRAIL_COUNT; i++) {
          trail[i].el.style.transform = `translate3d(${trail[i].x}px, ${trail[i].y}px, 0)`;
        }
        
        requestAnimationFrame(tick);
      })();

      document.addEventListener("astro:before-swap", () => {
        alive = false;
        window.removeEventListener("mousemove", onMove);
      }, { once: true });
    }
      // ── Progress bar ────────────────────────────────────────────────────
      const progressBar = document.createElement("div");
      progressBar.id = "progress-bar";
      document.body.appendChild(progressBar);

      // ── Back to top ─────────────────────────────────────────────────────
      const backToTop = document.createElement("button");
      backToTop.id = "back-to-top";
      backToTop.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="m16 12-4-4-4 4"/><path d="M12 16V8"/></svg>`;
      backToTop.setAttribute("aria-label", "Back to top");
      document.body.appendChild(backToTop);
      backToTop.addEventListener("click", () =>
        window.scrollTo({ top: 0, behavior: "smooth" }),
      );

      const onScroll = () => {
        const scrollTop = window.scrollY;
        const docHeight =
          document.documentElement.scrollHeight - window.innerHeight;
        const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
        progressBar.style.width = `${progress}%`;
        progressBar.style.boxShadow =
          progress > 95 ? "0 0 12px #0fd28c, 0 0 24px #6b21d4" : "none";
        backToTop.style.opacity = scrollTop > 300 ? "1" : "0";
        backToTop.style.pointerEvents = scrollTop > 300 ? "auto" : "none";
      };
      window.addEventListener("scroll", onScroll);
      document.addEventListener(
        "astro:before-swap",
        () => window.removeEventListener("scroll", onScroll),
        { once: true },
      );

      // ── Nav scramble ────────────────────────────────────────────────────
      const chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%";
      document
        .querySelectorAll(".nav-links a, .nav-drawer ul li a")
        .forEach((link) => {
          const original = link.textContent.trim();
          let interval;
          const scramble = () => {
            let iterations = 0;
            clearInterval(interval);
            interval = setInterval(() => {
              link.textContent = original
                .split("")
                .map((char, i) => {
                  if (char === " ") return " ";
                  if (i < iterations) return original[i];
                  return chars[Math.floor(Math.random() * chars.length)];
                })
                .join("");
              iterations += 0.5;
              if (iterations >= original.length) {
                clearInterval(interval);
                link.textContent = original;
              }
            }, 55);
          };
          const reset = () => {
            clearInterval(interval);
            link.textContent = original;
          };
          link.addEventListener("mouseenter", scramble);
          link.addEventListener("mouseleave", reset);
          link.addEventListener("touchstart", scramble, { passive: true });
        });
    }

    document.addEventListener("astro:page-load", initPersistentUI);
  </script>
</html>