---
interface Props {
  title?: string;
}
import "../styles/global.css";
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";
const { title = "Akif Zahin" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="I build AI-powered apps, full-stack tools, and solutions for real-world problems. Based in Dhaka, Bangladesh. Open to freelance and collaborations."
    />
    <meta name="author" content="Akif Zahin" />

    <!-- Open Graph -->
    <meta
      property="og:title"
      content="Akif Zahin — Full-stack Developer & AI Builder in Dhaka"
    />
    <meta
      property="og:description"
      content="I build AI-powered apps, full-stack tools, and solutions for real-world problems. Based in Dhaka, Bangladesh. Open to freelance and collaborations."
    />
    <meta property="og:image" content="https://akifzahin.dev/og.png" />
    <meta property="og:url" content="https://akifzahin.dev" />
    <meta property="og:type" content="website" />

    <!-- Twitter/X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:title"
      content="Akif Zahin — Full-stack Developer & AI Builder in Dhaka"
    />
    <meta
      name="twitter:description"
      content="I build AI-powered apps, full-stack tools, and solutions for real-world problems. Based in Dhaka, Bangladesh. Open to freelance and collaborations."
    />
    <meta name="twitter:image" content="https://akifzahin.dev/og.png" />
    <!-- Canonical -->
    <link rel="canonical" href="https://akifzahin.dev" />

    <!-- Schema -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        name: "Akif Zahin",
        url: "https://akifzahin.dev",
        jobTitle: "Full-stack Developer",
        address: {
          "@type": "PostalAddress",
          addressLocality: "Dhaka",
          addressCountry: "BD",
        },
        sameAs: [
          "https://github.com/akifzahin",
          "https://linkedin.com/in/akifzahin",
          "https://medium.com/@akifzahin",
        ],
      })}
    />

    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Share+Tech+Mono&family=Inter:wght@300;400&display=swap"
      rel="stylesheet"
    />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <slot />
    <Analytics />
    <SpeedInsights />
  </body>
</html>
