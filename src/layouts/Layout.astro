---
interface Props {
  title?: string;
  showBack?: boolean;
}
import "../styles/global.css";
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import ThemeSwitcher from "../components/ThemeSwitcher.astro";
import BackButton from "../components/BackButton.astro";
import { ClientRouter } from "astro:transitions";
const { title = "Akif Zahin", showBack = false } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="I build AI-powered apps, full-stack tools, and solutions for real-world problems. Based in Dhaka, Bangladesh. Open to freelance and collaborations."
    />
    <meta name="author" content="Akif Zahin" />
    <meta property="og:title" content="Akif Zahin — Full-stack Developer & AI Builder in Dhaka" />
    <meta property="og:description" content="I build AI-powered apps, full-stack tools, and solutions for real-world problems. Based in Dhaka, Bangladesh. Open to freelance and collaborations." />
    <meta property="og:image" content="https://akifzahin.dev/og.png" />
    <meta property="og:url" content="https://akifzahin.dev" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Akif Zahin — Full-stack Developer & AI Builder in Dhaka" />
    <meta name="twitter:description" content="I build AI-powered apps, full-stack tools, and solutions for real-world problems. Based in Dhaka, Bangladesh. Open to freelance and collaborations." />
    <meta name="twitter:image" content="https://akifzahin.dev/og.png" />
    <link rel="canonical" href="https://akifzahin.dev" />
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        name: "Akif Zahin",
        url: "https://akifzahin.dev",
        jobTitle: "Full-stack Developer",
        address: { "@type": "PostalAddress", addressLocality: "Dhaka", addressCountry: "BD" },
        sameAs: [
          "https://github.com/akifzahin",
          "https://linkedin.com/in/akifzahin",
          "https://medium.com/@akifzahin",
        ],
      })}
    />

    <!-- ClientRouter: enables SPA navigation -->
    <ClientRouter />

    <!--
      Theme flash prevention: must be inline + in <head> so it runs
      before the first paint on every hard load and SPA navigation.
    -->
    <script is:inline>
      (function () {
        var p = localStorage.getItem("theme-primary");
        var a = localStorage.getItem("theme-accent");
        var dark = localStorage.getItem("theme-dark");
        if (p && a) {
          var toRgb = function (hex) {
            return [1, 3, 5].map(function (o) { return parseInt(hex.slice(o, o + 2), 16); }).join(", ");
          };
          var root = document.documentElement;
          root.style.setProperty("--primary", p);
          root.style.setProperty("--accent", a);
          root.style.setProperty("--primary-rgb", toRgb(p));
          root.style.setProperty("--accent-rgb", toRgb(a));
          root.style.setProperty("--primary-dim", "rgba(" + toRgb(p) + ", 0.1)");
          root.style.setProperty("--primary-glow", "rgba(" + toRgb(p) + ", 0.4)");
          root.style.setProperty("--accent-dim", "rgba(" + toRgb(a) + ", 0.1)");
          root.style.setProperty("--accent-glow", "rgba(" + toRgb(a) + ", 0.4)");
        }
        if (dark === "false") document.documentElement.classList.add("light");
      })();
    </script>

    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Share+Tech+Mono&family=Inter:wght@300;400&display=swap" rel="stylesheet" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <div class="nav-wrapper">
      <nav>
        <div class="nav-left">
          <a href="/" class="logo font-display">
            <span class="logo-a">A</span><span class="logo-z">Z</span>
          </a>
          {showBack && <BackButton />}
          <ThemeSwitcher />
        </div>
        <ul class="nav-links">
          <li><a href="/#work">Work</a></li>
          <li><a href="/#skills">Skills</a></li>
          <li><a href="/#experience">Experience</a></li>
          <li><a href="/#about">About</a></li>
          <li><a href="/#contact">Contact</a></li>
          <li><a href="/blog">Blog</a></li>
        </ul>
        <button class="nav-hamburger" id="nav-hamburger" aria-label="Toggle menu">
          <span></span><span></span><span></span>
        </button>
      </nav>
      <div class="nav-drawer" id="nav-drawer">
        <ul>
          <li><a href="/#work">Work</a></li>
          <li><a href="/#skills">Skills</a></li>
          <li><a href="/#experience">Experience</a></li>
          <li><a href="/#about">About</a></li>
          <li><a href="/#contact">Contact</a></li>
          <li><a href="/blog" data-astro-prefetch>Blog</a></li>
        </ul>
      </div>
    </div>

    <slot />

    <Analytics />
    <SpeedInsights />
  </body>

  <!-- ── All persistent UI — recreated on every page-load ──────────────── -->
  <!--
    The body is fully swapped on each SPA navigation, so any elements
    appended to document.body are wiped. We recreate them all inside
    astro:page-load, which fires on hard load AND after every navigation.
    Window-level listeners (mousemove, scroll, mousedown) are registered
    once via a flag on window so they don't stack across navigations.
  -->
  <script>
    function initPersistentUI() {
      // ── Hamburger / drawer ──────────────────────────────────────────────
      const hamburger = document.getElementById("nav-hamburger");
      const drawer = document.getElementById("nav-drawer");
      hamburger?.addEventListener("click", () => {
        hamburger.classList.toggle("open");
        drawer?.classList.toggle("open");
      });
      drawer?.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => {
          hamburger?.classList.remove("open");
          drawer?.classList.remove("open");
        });
      });

      // ── Cursor + trail ──────────────────────────────────────────────────
      const cursor = document.createElement("div");
      cursor.id = "cursor";
      const cursorDot = document.createElement("div");
      cursorDot.id = "cursor-dot";
      document.body.appendChild(cursor);
      document.body.appendChild(cursorDot);

      const getPrimary = () =>
        getComputedStyle(document.documentElement).getPropertyValue("--primary").trim();
      const getAccent = () =>
        getComputedStyle(document.documentElement).getPropertyValue("--accent").trim();

      const trail = [];
      for (let i = 0; i < 8; i++) {
        const sq = document.createElement("div");
        const primary = getPrimary();
        sq.style.cssText = `position:fixed;pointer-events:none;z-index:99990;border:1px solid ${primary};width:${6 + i * 3}px;height:${6 + i * 3}px;opacity:0;will-change:transform;margin-left:-${3 + i * 1.5}px;margin-top:-${3 + i * 1.5}px;`;
        document.body.appendChild(sq);
        trail.push({ el: sq, x: 0, y: 0 });
      }

      const themeObserver = new MutationObserver(() => {
        const primary = getPrimary();
        trail.forEach((t) => (t.el.style.borderColor = primary));
      });
      themeObserver.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ["class", "data-theme"],
      });

      // Animation loop — one rAF chain per page load, previous one dies
      // when its cursor/trail elements are removed from the DOM.
      let mouseX = 0, mouseY = 0, cursorX = 0, cursorY = 0;
      let alive = true;

      function animateCursor() {
        if (!alive) return;
        cursorX += (mouseX - cursorX) * 0.12;
        cursorY += (mouseY - cursorY) * 0.12;
        cursor.style.transform = `translate(${cursorX}px, ${cursorY}px)`;
        trail[0].x = mouseX;
        trail[0].y = mouseY;
        for (let i = 1; i < 8; i++) {
          trail[i].x += (trail[i - 1].x - trail[i].x) * 0.35;
          trail[i].y += (trail[i - 1].y - trail[i].y) * 0.35;
        }
        trail.forEach((t, i) => {
          t.el.style.transform = `translate(${t.x}px,${t.y}px)`;
          t.el.style.opacity = (((8 - i) / 8) * 0.25).toFixed(2);
        });
        requestAnimationFrame(animateCursor);
      }
      animateCursor();

      // Stop this page's rAF loop before the next swap replaces the body
      document.addEventListener("astro:before-swap", () => { alive = false; }, { once: true });

      // Window listeners registered once total, not per navigation
      if (!window._cursorListenersAdded) {
        window._cursorListenersAdded = true;
        let moveTimeout;
        window.addEventListener("mousemove", (e) => {
          // Update shared coords — picked up by whichever animateCursor is live
          window._cursorMouseX = e.clientX;
          window._cursorMouseY = e.clientY;
        });
      }

      // Per-page mousemove that updates local mouseX/mouseY for this loop
      const onMove = (e) => { mouseX = e.clientX; mouseY = e.clientY;
        cursorDot.style.transform = `translate(${mouseX}px, ${mouseY}px)`;
        const accent = getAccent();
        cursor.style.borderColor = accent;
        cursor.style.boxShadow = `0 0 12px ${accent}`;
        cursorDot.style.background = accent;
        cursorDot.style.boxShadow = `0 0 6px ${accent}`;
        clearTimeout(window._cursorMoveTimeout);
        window._cursorMoveTimeout = setTimeout(() => {
          const primary = getPrimary();
          cursor.style.borderColor = primary;
          cursor.style.boxShadow = `0 0 6px ${primary}`;
          cursorDot.style.background = primary;
          cursorDot.style.boxShadow = `0 0 6px ${primary}`;
        }, 50);
      };
      window.addEventListener("mousemove", onMove);
      document.addEventListener("astro:before-swap", () => window.removeEventListener("mousemove", onMove), { once: true });

      const onDown = () => {
        cursor.style.transform = `translate(${cursorX + (Math.random() - 0.5) * 10}px, ${cursorY + (Math.random() - 0.5) * 10}px)`;
        const accent = getAccent();
        cursor.style.borderColor = accent;
        cursor.style.boxShadow = `0 0 16px ${accent}`;
        setTimeout(() => {
          const primary = getPrimary();
          cursor.style.borderColor = primary;
          cursor.style.boxShadow = `0 0 6px ${primary}`;
        }, 150);
      };
      document.addEventListener("mousedown", onDown);
      document.addEventListener("astro:before-swap", () => document.removeEventListener("mousedown", onDown), { once: true });

      // Cursor hover expand
      document.querySelectorAll("a, button").forEach((el) => {
        el.addEventListener("mouseenter", () => cursor.classList.add("cursor-hover"));
        el.addEventListener("mouseleave", () => cursor.classList.remove("cursor-hover"));
      });

      // ── Progress bar ────────────────────────────────────────────────────
      const progressBar = document.createElement("div");
      progressBar.id = "progress-bar";
      document.body.appendChild(progressBar);

      // ── Back to top ─────────────────────────────────────────────────────
      const backToTop = document.createElement("button");
      backToTop.id = "back-to-top";
      backToTop.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="m16 12-4-4-4 4"/><path d="M12 16V8"/></svg>`;
      backToTop.setAttribute("aria-label", "Back to top");
      document.body.appendChild(backToTop);
      backToTop.addEventListener("click", () =>
        window.scrollTo({ top: 0, behavior: "smooth" })
      );

      const onScroll = () => {
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
        progressBar.style.width = `${progress}%`;
        progressBar.style.boxShadow =
          progress > 95 ? "0 0 12px #0fd28c, 0 0 24px #6b21d4" : "none";
        backToTop.style.opacity = scrollTop > 300 ? "1" : "0";
        backToTop.style.pointerEvents = scrollTop > 300 ? "auto" : "none";
      };
      window.addEventListener("scroll", onScroll);
      document.addEventListener("astro:before-swap", () => window.removeEventListener("scroll", onScroll), { once: true });

      // ── Nav scramble ────────────────────────────────────────────────────
      const chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%";
      document.querySelectorAll(".nav-links a, .nav-drawer ul li a").forEach((link) => {
        const original = link.textContent.trim();
        let interval;
        const scramble = () => {
          let iterations = 0;
          clearInterval(interval);
          interval = setInterval(() => {
            link.textContent = original.split("").map((char, i) => {
              if (char === " ") return " ";
              if (i < iterations) return original[i];
              return chars[Math.floor(Math.random() * chars.length)];
            }).join("");
            iterations += 0.5;
            if (iterations >= original.length) {
              clearInterval(interval);
              link.textContent = original;
            }
          }, 55);
        };
        const reset = () => { clearInterval(interval); link.textContent = original; };
        link.addEventListener("mouseenter", scramble);
        link.addEventListener("mouseleave", reset);
        link.addEventListener("touchstart", scramble, { passive: true });
      });
    }

    document.addEventListener("astro:page-load", initPersistentUI);
  </script>
</html>