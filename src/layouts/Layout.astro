---
interface Props {
  title?: string;
  showBack?: boolean;
}
import "../styles/global.css";
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import ThemeSwitcher from "../components/ThemeSwitcher.astro";
import BackButton from "../components/BackButton.astro";
import { ClientRouter } from "astro:transitions";
const { title = "Akif Zahin", showBack = false } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="I build AI-powered apps, full-stack tools, and solutions for real-world problems. Based in Dhaka, Bangladesh. Open to freelance and collaborations."
    />
    <meta name="author" content="Akif Zahin" />
    <meta
      property="og:title"
      content="Akif Zahin — Full-stack Developer & AI Builder in Dhaka"
    />
    <meta
      property="og:description"
      content="I build AI-powered apps, full-stack tools, and solutions for real-world problems. Based in Dhaka, Bangladesh. Open to freelance and collaborations."
    />
    <meta property="og:image" content="https://akifzahin.dev/og.png" />
    <meta property="og:url" content="https://akifzahin.dev" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:title"
      content="Akif Zahin — Full-stack Developer & AI Builder in Dhaka"
    />
    <meta
      name="twitter:description"
      content="I build AI-powered apps, full-stack tools, and solutions for real-world problems. Based in Dhaka, Bangladesh. Open to freelance and collaborations."
    />
    <meta name="twitter:image" content="https://akifzahin.dev/og.png" />
    <link rel="canonical" href="https://akifzahin.dev" />
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        name: "Akif Zahin",
        url: "https://akifzahin.dev",
        jobTitle: "Full-stack Developer",
        address: {
          "@type": "PostalAddress",
          addressLocality: "Dhaka",
          addressCountry: "BD",
        },
        sameAs: [
          "https://github.com/akifzahin",
          "https://linkedin.com/in/akifzahin",
          "https://medium.com/@akifzahin",
        ],
      })}
    />

    <!-- ClientRouter: enables SPA navigation -->
    <ClientRouter />

    <!--
      Theme flash prevention: must be inline + in <head> so it runs
      before the first paint on every hard load and SPA navigation.
    -->
    <script is:inline>
      (function () {
        var p = localStorage.getItem("theme-primary");
        var a = localStorage.getItem("theme-accent");
        var dark = localStorage.getItem("theme-dark");
        if (p && a) {
          var toRgb = function (hex) {
            return [1, 3, 5]
              .map(function (o) {
                return parseInt(hex.slice(o, o + 2), 16);
              })
              .join(", ");
          };
          var root = document.documentElement;
          root.style.setProperty("--primary", p);
          root.style.setProperty("--accent", a);
          root.style.setProperty("--primary-rgb", toRgb(p));
          root.style.setProperty("--accent-rgb", toRgb(a));
          root.style.setProperty(
            "--primary-dim",
            "rgba(" + toRgb(p) + ", 0.1)",
          );
          root.style.setProperty(
            "--primary-glow",
            "rgba(" + toRgb(p) + ", 0.4)",
          );
          root.style.setProperty("--accent-dim", "rgba(" + toRgb(a) + ", 0.1)");
          root.style.setProperty(
            "--accent-glow",
            "rgba(" + toRgb(a) + ", 0.4)",
          );
        }
        if (dark === "false") document.documentElement.classList.add("light");
      })();
    </script>

    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Share+Tech+Mono&family=Inter:wght@300;400&display=swap"
      rel="stylesheet"
    />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css"
    />
    <!-- Three.js (required by Vanta) -->
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js"></script>
    <!-- Vanta effects -->
    <script is:inline src="https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.net.min.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.waves.min.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.fog.min.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.cells.min.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.topology.min.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.birds.min.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.dots.min.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.globe.min.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.halo.min.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.rings.min.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.ripple.min.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.trunk.min.js"></script>
  </head>
  <body>
    <!-- Vanta.js mount target — sits behind CSS grid via z-index -->
    <div id="vanta-bg"></div>
    <div class="nav-wrapper">
      <nav>
        <div class="nav-left">
          <a href="/" class="logo font-display">
            <span class="logo-a">A</span><span class="logo-z">Z</span>
          </a>
          {showBack && <BackButton />}
          <ThemeSwitcher />
        </div>
        <ul class="nav-links">
          <li><a href="/#work">Work</a></li>
          <li><a href="/#skills">Skills</a></li>
          <li><a href="/#experience">Experience</a></li>
          <li><a href="/#about">About</a></li>
          <li><a href="/#contact">Contact</a></li>
          <li><a href="/blog">Blog</a></li>
        </ul>
        <button
          class="nav-hamburger"
          id="nav-hamburger"
          aria-label="Toggle menu"
        >
          <span></span><span></span><span></span>
        </button>
      </nav>
      <div class="nav-drawer" id="nav-drawer">
        <ul>
          <li><a href="/#work">Work</a></li>
          <li><a href="/#skills">Skills</a></li>
          <li><a href="/#experience">Experience</a></li>
          <li><a href="/#about">About</a></li>
          <li><a href="/#contact">Contact</a></li>
          <li><a href="/blog" data-astro-prefetch>Blog</a></li>
        </ul>
      </div>
    </div>

    <slot />

    <Analytics />
    <SpeedInsights />
  </body><!-- ── All persistent UI — recreated on every page-load ──────────────── --><!--
    The body is fully swapped on each SPA navigation, so any elements
    appended to document.body are wiped. We recreate them all inside
    astro:page-load, which fires on hard load AND after every navigation.
    Window-level listeners (mousemove, scroll, mousedown) are registered
    once via a flag on window so they don't stack across navigations.
  -->
  <script>
    // ── Vanta background system ─────────────────────────────────────────────
  let vantaInstance: any = null;

  function hexToNum(hex: string): number {
    return parseInt(hex.replace('#', ''), 16);
  }

  function getVantaConfig(themeName: string, primary: string, accent: string): { effect: string; options: Record<string, any> } | null {
    const p = hexToNum(primary);
    const a = hexToNum(accent);
    const isDark = !document.documentElement.classList.contains('light');
    const bg = isDark ? 0x0a0a0a : 0xd7d7d7;
    const base = { el: '#vanta-bg', THREE: (window as any).THREE, mouseControls: true, touchControls: true, gyroControls: false };

    switch (themeName) {
      case 'Cyberpunk':
        // CSS grid handles Cyberpunk — no Vanta
        return null;

      case 'Webcore':
        return {
          effect: 'NET',
          options: { ...base, color: p, backgroundColor: bg, points: 9, maxDistance: 22, spacing: 18 }
        };

      case 'Retro Futurism':
        return {
          effect: 'RIPPLE',
          options: { ...base, color: p, bgcolor: bg, speed: 4, waveHeight: 25 }
        };

      case 'Mythic Fiction':
        return {
          effect: 'FOG',
          options: { ...base, highlightColor: p, midtoneColor: a, lowlightColor: 0x0a0005, baseColor: bg, blurFactor: 0.6, speed: 1.2, zoom: 0.9 }
        };

      case 'Dreamcore':
        return {
          effect: 'CELLS',
          options: { ...base, color1: p, color2: a, backgroundColor: bg, size: 2.5, speed: 1.2 }
        };

      case 'Cassette Futurism':
        return {
          effect: 'TRUNK',
          options: { ...base, color: p, backgroundColor: bg, spacing: 1.5, chaos: 2 }
        };

      default:
        // Custom or unknown — fallback to NET with user's colors
        return null;
    }
  }

  function destroyVanta() {
    if (vantaInstance) {
      try { vantaInstance.destroy(); } catch (_) {}
      vantaInstance = null;
    }
    document.body.classList.remove('has-vanta');
  }

  function initVanta(themeName: string, primary: string, accent: string) {
    destroyVanta();
    const VANTA = (window as any).VANTA;

    // Fallback: if Vanta hasn't loaded yet or effect missing, CSS grid takes over
    if (!VANTA) {
      console.warn('[vanta] VANTA not loaded — CSS grid fallback active');
      return;
    }

    const config = getVantaConfig(themeName, primary, accent);

    // Cyberpunk or unknown theme with no config → CSS grid stays, no Vanta
    if (!config) return;

    const effectFn = VANTA[config.effect];
    if (!effectFn) {
      console.warn(`[vanta] Effect VANTA.${config.effect} not found — CSS grid fallback active`);
      return;
    }

    try {
      vantaInstance = effectFn(config.options);
      document.body.classList.add('has-vanta');
    } catch (err) {
      console.warn('[vanta] Failed to init effect — CSS grid fallback active', err);
      destroyVanta();
    }
  }

  function initVantaFromStorage() {
    const themeName = localStorage.getItem('theme-name') ?? 'Cyberpunk';
    const primary   = localStorage.getItem('theme-primary') ?? '#0fd28c';
    const accent    = localStorage.getItem('theme-accent')  ?? '#f40bf4';
    initVanta(themeName, primary, accent);
  }

  function initPersistentUI() {
      // ── Vanta boot ──────────────────────────────────────────────────────
      initVantaFromStorage();

      // Re-register theme-change listener each page load (body is swapped by SPA)
      document.addEventListener('theme-change', (e: Event) => {
        const { name, primary, accent } = (e as CustomEvent).detail;
        initVanta(name, primary, accent);
      });

      // Tear down before SPA swap (once per page)
      document.addEventListener('astro:before-swap', destroyVanta, { once: true });

      // ── Hamburger / drawer ──────────────────────────────────────────────
      const hamburger = document.getElementById("nav-hamburger");
      const drawer = document.getElementById("nav-drawer");
      hamburger?.addEventListener("click", () => {
        hamburger.classList.toggle("open");
        drawer?.classList.toggle("open");
      });
      drawer?.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => {
          hamburger?.classList.remove("open");
          drawer?.classList.remove("open");
        });
      });

      // ── Cursor + trail ──────────────────────────────────────────────────
      if (window.matchMedia("(hover: none) and (pointer: coarse)").matches)
        return;
      const cursorBlob = document.createElement("div");
      cursorBlob.id = "cursor-blob";
      const cursorDot = document.createElement("div");
      cursorDot.id = "cursor-dot";
      document.body.appendChild(cursorBlob);
      document.body.appendChild(cursorDot);

      const TRAIL_COUNT = 8;
      const LERP_BLOB = 0.1;
      const LERP_TRAIL = 0.3;

      const getPrimary = () =>
        getComputedStyle(document.documentElement)
          .getPropertyValue("--primary")
          .trim();
      const getAccent = () =>
        getComputedStyle(document.documentElement)
          .getPropertyValue("--accent")
          .trim();

      const trail = Array.from({ length: TRAIL_COUNT }, (_, i) => {
        const el = document.createElement("div");
        const size = Math.max(1, 5 - i * 0.5);
        const color = i < TRAIL_COUNT / 2 ? getPrimary() : getAccent();
        el.style.cssText = `position:fixed;pointer-events:none;z-index:99997;border-radius:50%;width:${size}px;height:${size}px;margin-left:-${size / 2}px;margin-top:-${size / 2}px;opacity:${(1 - i / TRAIL_COUNT).toFixed(2)};background:${color};`;
        document.body.appendChild(el);
        return { el, x: 0, y: 0 };
      });

      let mx = 0,
        my = 0,
        bx = 0,
        by = 0;
      let alive = true;

      const onMove = (e) => {
        mx = e.clientX;
        my = e.clientY;
        cursorDot.style.left = mx + "px";
        cursorDot.style.top = my + "px";
      };
      window.addEventListener("mousemove", onMove);
      document.addEventListener(
        "astro:before-swap",
        () => window.removeEventListener("mousemove", onMove),
        { once: true },
      );

      document.querySelectorAll("a, button, [data-hover]").forEach((el) => {
        el.addEventListener("mouseenter", () => {
          cursorBlob.classList.add("cursor-hover");
          cursorDot.classList.add("cursor-hover");
        });
        el.addEventListener("mouseleave", () => {
          cursorBlob.classList.remove("cursor-hover");
          cursorDot.classList.remove("cursor-hover");
        });
      });

      (function tick() {
        if (!alive) return;
        bx += (mx - bx) * LERP_BLOB;
        by += (my - by) * LERP_BLOB;
        cursorBlob.style.left = bx + "px";
        cursorBlob.style.top = by + "px";

        trail[0].x += (mx - trail[0].x) * LERP_TRAIL;
        trail[0].y += (my - trail[0].y) * LERP_TRAIL;
        for (let i = 1; i < TRAIL_COUNT; i++) {
          trail[i].x += (trail[i - 1].x - trail[i].x) * LERP_TRAIL;
          trail[i].y += (trail[i - 1].y - trail[i].y) * LERP_TRAIL;
        }

        const primary = getPrimary();
        const accent = getAccent();
        trail.forEach((d, i) => {
          d.el.style.left = d.x + "px";
          d.el.style.top = d.y + "px";
          d.el.style.background = i < TRAIL_COUNT / 2 ? primary : accent;
        });
        requestAnimationFrame(tick);
      })();

      document.addEventListener(
        "astro:before-swap",
        () => {
          alive = false;
        },
        { once: true },
      );

      // ── Progress bar ────────────────────────────────────────────────────
      const progressBar = document.createElement("div");
      progressBar.id = "progress-bar";
      document.body.appendChild(progressBar);

      // ── Back to top ─────────────────────────────────────────────────────
      const backToTop = document.createElement("button");
      backToTop.id = "back-to-top";
      backToTop.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="m16 12-4-4-4 4"/><path d="M12 16V8"/></svg>`;
      backToTop.setAttribute("aria-label", "Back to top");
      document.body.appendChild(backToTop);
      backToTop.addEventListener("click", () =>
        window.scrollTo({ top: 0, behavior: "smooth" }),
      );

      const onScroll = () => {
        const scrollTop = window.scrollY;
        const docHeight =
          document.documentElement.scrollHeight - window.innerHeight;
        const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
        progressBar.style.width = `${progress}%`;
        progressBar.style.boxShadow =
          progress > 95 ? "0 0 12px #0fd28c, 0 0 24px #6b21d4" : "none";
        backToTop.style.opacity = scrollTop > 300 ? "1" : "0";
        backToTop.style.pointerEvents = scrollTop > 300 ? "auto" : "none";
      };
      window.addEventListener("scroll", onScroll);
      document.addEventListener(
        "astro:before-swap",
        () => window.removeEventListener("scroll", onScroll),
        { once: true },
      );

      // ── Nav scramble ────────────────────────────────────────────────────
      const chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%";
      document
        .querySelectorAll(".nav-links a, .nav-drawer ul li a")
        .forEach((link) => {
          const original = link.textContent.trim();
          let interval;
          const scramble = () => {
            let iterations = 0;
            clearInterval(interval);
            interval = setInterval(() => {
              link.textContent = original
                .split("")
                .map((char, i) => {
                  if (char === " ") return " ";
                  if (i < iterations) return original[i];
                  return chars[Math.floor(Math.random() * chars.length)];
                })
                .join("");
              iterations += 0.5;
              if (iterations >= original.length) {
                clearInterval(interval);
                link.textContent = original;
              }
            }, 55);
          };
          const reset = () => {
            clearInterval(interval);
            link.textContent = original;
          };
          link.addEventListener("mouseenter", scramble);
          link.addEventListener("mouseleave", reset);
          link.addEventListener("touchstart", scramble, { passive: true });
        });
    }

    document.addEventListener("astro:page-load", initPersistentUI);
  </script>
</html>