---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404 — Not Found">
  <section class="hero ready">
    <div class="hero-content">
      <p
        class="hero-eyebrow font-mono"
        style="animation:none; width:auto; border-right:none; opacity:1;"
      >
        — ERROR 404
      </p>
      <h1 class="hero-name font-display" style="opacity:1;">
        <span class="name-outline">PAGE</span>
        <span class="name-glow">LOST.</span>
      </h1>
      <p class="hero-sub" style="opacity:1;">
        This sector doesn't exist or has been decommissioned.
      </p>
      <div class="cta-row" style="opacity:1;">
        <a href="/" class="btn-primary btn-download">
          <span class="btn-label">Return Home</span>
          <span class="btn-icon">
            <svg
              class="icon-default"
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"
              ></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg
            >
            <svg
              class="icon-hover"
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="m12 19-7-7 7-7"></path><path d="M19 12H5"></path></svg
            >
          </span>
        </a>
      </div>
    </div>
  </section>
</Layout>
