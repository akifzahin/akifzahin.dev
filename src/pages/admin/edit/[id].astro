---
export const prerender = false;
import Layout from "../../../layouts/Layout.astro";
import PostEditor from "../../../components/admin/PostEditor.tsx";
import BackButton from "../../../components/BackButton.astro";

const { id } = Astro.params;
const postId = Number(id);
---

<Layout title="Edit Post — Admin">
  <main class="admin-editor-page">
    <div class="admin-editor-inner">
      <BackButton />
      <PostEditor client:load postId={postId} />
    </div>
  </main>
</Layout>

<style is:global>
  body::before {
    display: none !important;
  }
  body::after {
    display: none !important;
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const vantaMount = document.getElementById("vanta-bg");
    if (vantaMount) vantaMount.style.display = "none";
  });
</script>
