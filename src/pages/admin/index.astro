---
export const prerender = false;
import Layout from "../../layouts/Layout.astro";
import BackButton from "../../components/BackButton.astro";
import BackToTop from "../../components/BackToTop.astro";
---

<Layout title="Drafts — Admin">
  <main class="admin-dashboard">
    <div class="admin-dashboard-inner">
      <BackButton />

      <!-- 1. The main two-column grid wrapper -->
      <div class="admin-split-grid">
        
        <!-- LEFT COLUMN: Posts -->
        <div class="admin-split-col">
          <!-- 2. We moved the header inside this column so it aligns with the right column -->
          <div class="admin-dashboard-header">
            <h1 class="font-display">
              <span class="glitch-outline" data-text="Your">Your</span>
              <span class="glitch-glow" data-text="Posts">Posts</span>
            </h1>
            <a href="/admin/new" class="btn-primary">
              <span class="btn-label">+ New Post</span>
            </a>
          </div>

          <div id="posts-list" class="admin-posts-list">
            <p class="font-mono admin-loading">Loading...</p>
          </div>
          <nav id="admin-pagination" class="pagination font-mono"></nav>
        </div>

        <!-- RIGHT COLUMN: Comments -->
        <div class="admin-split-col">
          <div class="admin-comments-section">
            <h1 class="font-display">
              <span class="glitch-outline" data-text="Pending">Pending</span>
              <span class="glitch-glow" data-text="Comments">Comments</span>
            </h1>
            <div id="comments-list" class="admin-posts-list">
              <p class="font-mono admin-loading">Loading...</p>
            </div>
          </div>
        </div>

      </div> <!-- End of admin-split-grid -->
    </div>
  </main>
</Layout>

<script>
  document.addEventListener("astro:page-load", async () => {
    const list = document.getElementById("posts-list");
    const paginationEl = document.getElementById("admin-pagination");
    if (!list || !paginationEl) return;

    const POSTS_PER_PAGE = 8;
    let allPosts: any[] = [];
    let currentPage = 1;

    function renderPage() {
      const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);
      const start = (currentPage - 1) * POSTS_PER_PAGE;
      const pagePosts = allPosts.slice(start, start + POSTS_PER_PAGE);

      // 1. Generate and insert the HTML for all the post cards
      list!.innerHTML = pagePosts
        .map((post: any) => {
          const isDraft = post.draft === 1;

          // Fallback text if title or description are blank
          const displayTitle = post.title || "Untitled Post";
          const displayDesc =
            post.description || "No description provided for this post.";

          // Render the image tag if it exists, otherwise render the inline SVG icon
          const thumbVisual = post.cover_image
            ? `<img src="${post.cover_image}" alt="" class="admin-post-thumb" />`
            : `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-book-open-text-icon lucide-book-open-text admin-post-thumb"><path d="M12 7v14"/><path d="M16 12h2"/><path d="M16 8h2"/><path d="M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z"/><path d="M6 12h2"/><path d="M6 8h2"/></svg>`;

          // Return the full wrapper structure including the card and the delete button
          return `
      <div class="admin-post-card-wrap">
        <a href="/admin/edit/${post.id}" class="admin-post-card">
          <div class="admin-post-card-row">
            ${thumbVisual}
            <div class="admin-post-card-text">
              <div class="admin-post-card-top">
                <span class="admin-post-title">${displayTitle}</span>
                <span class="admin-post-status ${isDraft ? "draft" : "published"} font-mono">
                  ${isDraft ? "Draft" : "Published"}
                </span>
              </div>
              <p class="admin-post-desc">${displayDesc}</p>
            </div>
          </div>
        </a>
        <button type="button" class="admin-post-delete" data-id="${post.id}" aria-label="Delete post">×</button>
      </div>
    `;
        })
        .join("");

      // 2. Find all the newly created delete buttons and attach click listeners to them
      list!.querySelectorAll(".admin-post-delete").forEach((btn) => {
        btn.addEventListener("click", (e) => {
          e.preventDefault();
          e.stopPropagation();
          handleDeleteClick(btn as HTMLElement);
        });
      });

      renderPagination(totalPages);
    }
    async function handleDeleteClick(btn: HTMLElement) {
      const id = btn.dataset.id;
      const alreadyConfirming = btn.classList.contains("confirming");

      if (!alreadyConfirming) {
        btn.classList.add("confirming");
        btn.textContent = "Sure?";
        setTimeout(() => {
          if (btn.classList.contains("confirming")) {
            btn.classList.remove("confirming");
            btn.textContent = "×";
          }
        }, 3000); // auto-revert if they don't confirm in time
        return;
      }

      btn.textContent = "...";
      try {
        await fetch(`/api/admin/posts/${id}`, { method: "DELETE" });
        allPosts = allPosts.filter((p) => p.id !== Number(id));
        if (
          (currentPage - 1) * POSTS_PER_PAGE >= allPosts.length &&
          currentPage > 1
        ) {
          currentPage--; // step back a page if we just emptied the last one
        }
        if (allPosts.length === 0) {
          list!.innerHTML = `<p class="admin-empty font-mono">No posts yet. Create your first one.</p>`;
          paginationEl!.innerHTML = "";
        } else {
          renderPage();
        }
      } catch {
        btn.textContent = "×";
        btn.classList.remove("confirming");
      }
    }
    function renderPagination(totalPages: number) {
      if (totalPages <= 1) {
        paginationEl!.innerHTML = "";
        return;
      }

      const pageNumbers = Array.from({ length: totalPages }, (_, i) => i + 1)
        .map(
          (n) =>
            `<button class="page-btn ${n === currentPage ? "active" : ""}" data-page="${n}">${n}</button>`,
        )
        .join("");

      paginationEl!.innerHTML = `
        <div class="page-numbers">
          ${currentPage > 1 ? `<button class="page-btn" data-page="${currentPage - 1}">← Prev</button>` : ""}
          ${pageNumbers}
          ${currentPage < totalPages ? `<button class="page-btn" data-page="${currentPage + 1}">Next →</button>` : ""}
        </div>
      `;

      paginationEl!.querySelectorAll("[data-page]").forEach((btn) => {
        btn.addEventListener("click", () => {
          currentPage = Number((btn as HTMLElement).dataset.page);
          renderPage();
          list!.scrollIntoView({ behavior: "smooth", block: "start" });
        });
      });
    }

    try {
      const res = await fetch("/api/admin/posts");
      allPosts = await res.json();

      if (allPosts.length === 0) {
        list.innerHTML = `<p class="admin-empty font-mono">No posts yet. Create your first one.</p>`;
        return;
      }

      renderPage();
    } catch (err) {
      list.innerHTML = `<p class="admin-empty font-mono">Failed to load posts.</p>`;
    }
  });
</script>
<script>
  document.addEventListener("astro:page-load", async () => {
    const list = document.getElementById("comments-list");
    if (!list) return;

    function escapeHtml(str: string) {
      const div = document.createElement("div");
      div.textContent = str;
      return div.innerHTML;
    }

    async function loadComments() {
      try {
        const res = await fetch("/api/admin/comments");
        const comments = await res.json();

        if (!Array.isArray(comments) || comments.length === 0) {
          list!.innerHTML = `<p class="admin-empty font-mono">No pending comments.</p>`;
          return;
        }

        list!.innerHTML = comments
          .map(
            (c: any) => `
          <div class="admin-post-card-wrap" data-comment-id="${c.id}">
            <div class="admin-post-card admin-comment-card">
              <div class="admin-post-card-text">
                <div class="admin-post-card-top">
                  <span class="admin-post-title">${escapeHtml(c.name)}</span>
                  <span class="admin-post-status draft font-mono">on "${escapeHtml(c.post_title)}"</span>
                </div>
                <p class="admin-post-desc">${escapeHtml(c.body)}</p>
              </div>
            </div>
            <div class="admin-comment-actions">
              <button type="button" class="admin-comment-approve" data-id="${c.id}">Approve</button>
              <button type="button" class="admin-comment-reject" data-id="${c.id}">Reject</button>
            </div>
          </div>
        `,
          )
          .join("");

        list!.querySelectorAll(".admin-comment-approve").forEach((btn) => {
          btn.addEventListener("click", async () => {
            const id = (btn as HTMLElement).dataset.id;
            (btn as HTMLElement).textContent = "...";
            await fetch(`/api/admin/comments/${id}`, { method: "POST" });
            document.querySelector(`[data-comment-id="${id}"]`)?.remove();
            if (!list!.querySelector("[data-comment-id]")) {
              list!.innerHTML = `<p class="admin-empty font-mono">No pending comments.</p>`;
            }
          });
        });

        list!.querySelectorAll(".admin-comment-reject").forEach((btn) => {
          btn.addEventListener("click", async () => {
            const id = (btn as HTMLElement).dataset.id;
            (btn as HTMLElement).textContent = "...";
            await fetch(`/api/admin/comments/${id}`, { method: "DELETE" });
            document.querySelector(`[data-comment-id="${id}"]`)?.remove();
            if (!list!.querySelector("[data-comment-id]")) {
              list!.innerHTML = `<p class="admin-empty font-mono">No pending comments.</p>`;
            }
          });
        });
      } catch {
        list!.innerHTML = `<p class="admin-empty font-mono">Failed to load comments.</p>`;
      }
    }

    loadComments();
  });
</script>
