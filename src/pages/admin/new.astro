---
export const prerender = false;
import Layout from "../../layouts/Layout.astro";
import PostEditor from "../../components/admin/PostEditor.tsx";
---

<Layout title="New Post — Admin">
  <main class="admin-editor-page">
    <div class="admin-editor-inner">
      <a href="/admin" class="admin-back-link font-mono">← Back to posts</a>
      <PostEditor client:load />
    </div>
  </main>
</Layout>

<style is:global>
  body::before {
    display: none !important;
  }
  body::after {
    display: none !important;
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const vantaMount = document.getElementById("vanta-bg");
    if (vantaMount) vantaMount.style.display = "none";
  });
</script>
