---
export const prerender = false;
import Layout from "../../layouts/Layout.astro";
import PostEditor from "../../components/admin/PostEditor.tsx";
import BackButton from "../../components/BackButton.astro";
---

<Layout title="New Post — Admin" noindex={true}>
  <main class="admin-editor-page">
    <div class="admin-editor-inner">
      <!-- <a href="/admin" class="admin-back-link font-mono">← Back to posts</a> -->
      <BackButton />
      <PostEditor client:load />
    </div>
  </main>
</Layout>

<style is:global>
  body::before {
    display: none !important;
  }
  body::after {
    display: none !important;
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const vantaMount = document.getElementById("vanta-bg");
    if (vantaMount) vantaMount.style.display = "none";
  });

  document.addEventListener(
    "astro:before-swap",
    () => {
      const vantaMount = document.getElementById("vanta-bg");
      if (vantaMount) vantaMount.style.display = "";
    },
    { once: true },
  );
</script>
