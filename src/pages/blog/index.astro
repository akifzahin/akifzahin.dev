---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout title="Blog — Akif Zahin">
  <main class="blog-index">
    <div class="blog-index-inner">
      <h1 class="blog-heading font-display">Blog</h1>
      <p class="blog-subheading font-mono">— thoughts, lessons, observations</p>

      <ul class="post-list">
        {posts.map(post => (
          <li class="post-card">
            <a href={`/blog/${post.id}`}>
              <span class="post-date font-mono">
                {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </span>
              <h2 class="post-title">{post.data.title}</h2>
              <p class="post-desc">{post.data.description}</p>
              {post.data.tags && (
                <div class="post-tags">
                  {post.data.tags.map(tag => <span class="tag font-mono">#{tag}</span>)}
                </div>
              )}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </main>
    <!-- FOOTER -->
  <footer>
    <p class="footer-copy font-mono">© 2026 Akif Zahin</p>
  </footer>
</Layout>