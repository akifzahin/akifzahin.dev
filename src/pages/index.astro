      class="hero-deco"
      viewBox="0 0 300 300"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <circle cx="150" cy="150" r="140" stroke="#0fd28c" stroke-width="1"
