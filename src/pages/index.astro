---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Akif Zahin">
  <!-- NAV -->
  <nav>
    <div class="logo font-display">AZ</div>
    <ul class="nav-links">
      <li><a href="#work">Work</a></li>
      <li><a href="#blog">Blog</a></li>
      <li><a href="#about">About</a></li>
      <li><a href="#contact">Contact</a></li>
    </ul>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-content">
      <p class="hero-eyebrow font-mono">— Full-stack developer &amp; builder</p>
      <h1 class="hero-name font-display">
        <span class="name-outline">Akif</span>
        <span class="name-glow">Zahin</span>
      </h1>
      <p class="hero-sub">
        Building <span class="accent-purple">products that matter</span> — from insurance
        tools to AI-powered apps. Based in Dhaka, Bangladesh.
      </p>
      <div class="cta-row">
        <a href="#work" class="btn-primary">View Work</a>
        <a href="#blog" class="btn-ghost">Read Blog</a>
      </div>

      <!-- Social Icons -->
      <div class="social-row">
        <a
          href="https://github.com/akifzahin"
          target="_blank"
          rel="noopener"
          aria-label="GitHub"
          class="social-link"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="currentColor"
          >
            <path
              d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"
            ></path>
          </svg>
        </a>
        <a
          href="https://linkedin.com/in/akifzahin/"
          target="_blank"
          rel="noopener"
          aria-label="LinkedIn"
          class="social-link"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="currentColor"
          >
            <path
              d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
            ></path>
          </svg>
        </a>
        <a
          href="https://facebook.com/zahinakif25"
          target="_blank"
          rel="noopener"
          aria-label="Facebook"
          class="social-link"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="currentColor"
          >
            <path
              d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.312 0 2.686.236 2.686.236v2.97h-1.513c-1.491 0-1.956.93-1.956 1.886v2.267h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"
            ></path>
          </svg>
        </a>
      </div>
    </div>

    <!-- Profile pic -->
    <div class="hero-profile">
      <div class="profile-frame">
        <!-- Replace /images/profile.jpg with your actual photo in the public/ folder -->
        <img src="../src/assets/dp.jpg" alt="Akif Zahin" class="profile-img" />
        <div class="profile-glow"></div>
      </div>
      <p class="corner-tag font-mono">SYS::PORTFOLIO_v1.0</p>
    </div>

    <!-- Geometric deco -->
    <svg
      class="hero-deco"
      viewBox="0 0 300 300"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <circle cx="150" cy="150" r="140" stroke="#0fd28c" stroke-width="1"
      ></circle>
      <circle cx="150" cy="150" r="100" stroke="#6b21d4" stroke-width="1"
      ></circle>
      <circle cx="150" cy="150" r="60" stroke="#0fd28c" stroke-width="1"
      ></circle>
      <line
        x1="10"
        y1="150"
        x2="290"
        y2="150"
        stroke="#0fd28c"
        stroke-width="0.5"></line>
      <line
        x1="150"
        y1="10"
        x2="150"
        y2="290"
        stroke="#0fd28c"
        stroke-width="0.5"></line>
      <line
        x1="50"
        y1="50"
        x2="250"
        y2="250"
        stroke="#6b21d4"
        stroke-width="0.5"></line>
      <line
        x1="250"
        y1="50"
        x2="50"
        y2="250"
        stroke="#6b21d4"
        stroke-width="0.5"></line>
      <rect
        x="130"
        y="130"
        width="40"
        height="40"
        stroke="#0fd28c"
        stroke-width="1"
        fill="none"></rect>
      <circle cx="150" cy="150" r="4" fill="#0fd28c"></circle>
    </svg>
  </section>

  <!-- WORK -->
  <section class="section" id="work">
    <p class="section-label">Selected work</p>
    <div class="projects-grid">
      <div class="project-card">
        <p class="project-num font-mono">001</p>
        <h3 class="project-title font-display">Insurance Report Tool</h3>
        <p class="project-desc">
          Automated Excel reporting system for non-technical staff. Saves hours
          of manual work weekly.
        </p>
        <div class="project-tags">
          <span class="tag">Python</span>
          <span class="tag">OpenPyXL</span>
          <span class="tag">Tkinter</span>
        </div>
      </div>
      <div class="project-card">
        <p class="project-num font-mono">002</p>
        <h3 class="project-title font-display">Stray Dog Rescue App</h3>
        <p class="project-desc">
          CV model for injury/disease detection. Community rescue coordination
          for street animals in BD.
        </p>
        <div class="project-tags">
          <span class="tag">Next.js</span>
          <span class="tag">PyTorch</span>
          <span class="tag">Supabase</span>
        </div>
      </div>
      <div class="project-card">
        <p class="project-num font-mono">003</p>
        <h3 class="project-title font-display">SME Invoicing Tool</h3>
        <p class="project-desc">
          Inventory and invoice management with Bangla UI support. Built for
          Bangladeshi small businesses.
        </p>
        <div class="project-tags">
          <span class="tag">Astro</span>
          <span class="tag">Supabase</span>
          <span class="tag">Bangla UI</span>
        </div>
      </div>
    </div>
  </section>

  <!-- BLOG -->
  <section class="section" id="blog">
    <p class="section-label">Recent writing</p>
    <div class="posts-list">
      <a href="/blog/excel-automation" class="post-item">
        <span class="post-title"
          >Building Excel automation tools non-devs can actually use</span
        >
        <span class="post-date font-mono">2026-05</span>
      </a>
      <a href="/blog/why-astro" class="post-item">
        <span class="post-title">Why I chose Astro for my personal site</span>
        <span class="post-date font-mono">2026-04</span>
      </a>
      <a href="/blog/cv-social-impact" class="post-item">
        <span class="post-title"
          >Computer vision for social impact in Bangladesh</span
        >
        <span class="post-date font-mono">2026-03</span>
      </a>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="section" id="about">
    <p class="section-label">About</p>
    <div class="about-grid">
      <p class="about-text">
React and Python developer interested in building fullstack applications using integration with AI. Based in Dhaka, Bangladesh.
      </p>
      <div class="about-links">
        <a
          href="https://github.com/yourusername"
          class="about-link font-mono"
          target="_blank"
          rel="noopener">GitHub ↗</a
        >
        <a
          href="https://linkedin.com/in/yourusername"
          class="about-link font-mono"
          target="_blank"
          rel="noopener">LinkedIn ↗</a
        >
        <a
          href="https://facebook.com/yourusername"
          class="about-link font-mono"
          target="_blank"
          rel="noopener">Facebook ↗</a
        >
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section class="section" id="contact">
    <p class="section-label">Contact</p>
    <div class="contact-grid">
      <div class="contact-left">
        <h2 class="contact-heading font-display">
          Let's build<br /><span class="name-glow">something.</span>
        </h2>
        <p class="contact-sub">
          Open to freelance work, collaborations, and interesting conversations.
        </p>
        <div class="contact-social">
          <a
            href="https://github.com/yourusername"
            target="_blank"
            rel="noopener"
            aria-label="GitHub"
            class="social-link"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path
                d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"
              ></path>
            </svg>
          </a>
          <a
            href="https://linkedin.com/in/yourusername"
            target="_blank"
            rel="noopener"
            aria-label="LinkedIn"
            class="social-link"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              ></path>
            </svg>
          </a>
          <a
            href="https://facebook.com/yourusername"
            target="_blank"
            rel="noopener"
            aria-label="Facebook"
            class="social-link"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path
                d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.312 0 2.686.236 2.686.236v2.97h-1.513c-1.491 0-1.956.93-1.956 1.886v2.267h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"
              ></path>
            </svg>
          </a>
        </div>
      </div>
      <form class="contact-form" onsubmit="handleSubmit(event)">
        <div class="form-group">
          <label class="form-label font-mono" for="name">Name</label>
          <input
            class="form-input font-mono"
            type="text"
            id="name"
            name="name"
            placeholder="Your name"
            required
          />
        </div>
        <div class="form-group">
          <label class="form-label font-mono" for="email">Email</label>
          <input
            class="form-input font-mono"
            type="email"
            id="email"
            name="email"
            placeholder="your@email.com"
            required
          />
        </div>
        <div class="form-group">
          <label class="form-label font-mono" for="message">Message</label>
          <textarea
            class="form-input font-mono"
            id="message"
            name="message"
            rows="5"
            placeholder="What's on your mind?"
            required></textarea>
        </div>
        <button
          type="submit"
          class="btn-primary"
          style="width:100%; text-align:center; cursor:crosshair;"
          >Send Message</button
        >
      </form>
    </div>
  </section>

  <!-- FOOTER -->
  <footer>
    <ul class="footer-links">
      <li>
        <a
          href="https://github.com/yourusername"
          target="_blank"
          rel="noopener"
          class="font-mono">GitHub</a>
      </li>
      <li>
        <a
          href="https://linkedin.com/in/yourusername"
          target="_blank"
          rel="noopener"
          class="font-mono">LinkedIn</a>
      </li>
      <li>
        <a
          href="https://facebook.com/yourusername"
          target="_blank"
          rel="noopener"
          class="font-mono">Facebook</a>
      </li>
    </ul>
    <p class="footer-copy font-mono">© 2026 Akif Zahin</p>
  </footer>
</Layout>

<script>
  function handleSubmit(e: Event) {
    e.preventDefault();
    const btn = (e.target as HTMLFormElement).querySelector(
      'button[type="submit"]',
    ) as HTMLButtonElement;
    btn.textContent = "Sent ✓";
    btn.style.color = "#0fd28c";
    btn.disabled = true;
  }
</script>

<style>
  nav {
    position: relative;
    z-index: 10;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 3rem;
    border-bottom: 1px solid rgba(15, 210, 140, 0.15);
  }

  .logo {
    font-size: 1.2rem;
    font-weight: 900;
    color: #0fd28c;
    letter-spacing: 0.1em;
    text-shadow: 0 0 20px rgba(15, 210, 140, 0.5);
  }

  .nav-links {
    display: flex;
    gap: 2.5rem;
    list-style: none;
  }

  .nav-links a {
    font-family: "Share Tech Mono", monospace;
    font-size: 0.75rem;
    color: #888;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    transition: color 0.2s;
  }

  .nav-links a:hover {
    color: #0fd28c;
  }

  /* HERO */
  .hero {
    position: relative;
    z-index: 5;
    min-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 4rem 3rem;
    overflow: hidden;
    /* Cyberpunk city image with deep purple overlay */
    background:
      linear-gradient(
        135deg,
        rgba(10, 0, 16, 0.88) 0%,
        rgba(60, 0, 100, 0.82) 60%,
        rgba(10, 0, 16, 0.92) 100%
      ),
      url("../src/assets/background.jpg") center/cover no-repeat;
  }

  .hero-content {
    flex: 1;
    max-width: 600px;
    z-index: 2;
  }

  .hero-eyebrow {
    font-size: 0.75rem;
    color: #0fd28c;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    opacity: 0.8;
  }

  .hero-name {
    font-size: clamp(3.5rem, 10vw, 8rem);
    line-height: 0.9;
    text-transform: uppercase;
    letter-spacing: -0.02em;
  }

  .name-outline {
    display: block;
    color: transparent;
    -webkit-text-stroke: 2px #6b21d4;
  }

  .name-glow {
    display: block;
    color: #0fd28c;
    text-shadow: 0 0 60px rgba(15, 210, 140, 0.35);
  }

  .hero-sub {
    margin-top: 2rem;
    font-size: 1rem;
    color: #888;
    max-width: 480px;
    line-height: 1.7;
  }

  .accent-purple {
    color: #c084fc;
  }

  .cta-row {
    margin-top: 2.5rem;
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  /* Social icons */
  .social-row {
    margin-top: 2rem;
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: 1px solid rgba(15, 210, 140, 0.2);
    color: #555;
    transition: all 0.2s;
  }

  .social-link:hover {
    color: #0fd28c;
    border-color: #0fd28c;
    box-shadow: 0 0 12px rgba(15, 210, 140, 0.2);
  }

  /* Profile */
  .hero-profile {
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.75rem;
    padding-left: 3rem;
    align-self: flex-end;
    padding-bottom: 1rem;
  }

  .profile-frame {
    position: relative;
    width: 220px;
    height: 220px;
  }

  .profile-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: grayscale(20%) contrast(1.1);
    clip-path: polygon(10% 0%, 100% 0%, 100% 90%, 90% 100%, 0% 100%, 0% 10%);
  }

  .profile-frame::before {
    content: "";
    position: absolute;
    inset: -2px;
    background: linear-gradient(135deg, #0fd28c, #6b21d4);
    clip-path: polygon(10% 0%, 100% 0%, 100% 90%, 90% 100%, 0% 100%, 0% 10%);
    z-index: -1;
  }

  .profile-glow {
    position: absolute;
    inset: -20px;
    background: radial-gradient(
      ellipse,
      rgba(15, 210, 140, 0.12),
      transparent 70%
    );
    pointer-events: none;
  }

  .corner-tag {
    font-family: "Share Tech Mono", monospace;
    font-size: 0.6rem;
    color: #333;
    letter-spacing: 0.1em;
  }

  .hero-deco {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 500px;
    height: 500px;
    opacity: 0.06;
    pointer-events: none;
  }

  /* SECTIONS */
  .section {
    position: relative;
    z-index: 5;
    padding: 5rem 3rem;
    border-top: 1px solid rgba(255, 255, 255, 0.04);
  }

  /* PROJECTS */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1px;
    background: rgba(255, 255, 255, 0.04);
  }

  .project-card {
    background: #0a0010;
    padding: 2rem;
    transition: background 0.2s;
  }
  .project-card:hover {
    background: rgba(15, 210, 140, 0.03);
  }

  .project-num {
    font-family: "Share Tech Mono", monospace;
    font-size: 0.65rem;
    color: #333;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
  }
  .project-title {
    font-family: "Orbitron", sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 0.75rem;
    letter-spacing: 0.05em;
  }
  .project-desc {
    font-size: 0.8rem;
    color: #555;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }
  .project-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  /* BLOG */
  .posts-list {
    display: flex;
    flex-direction: column;
  }

  .post-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 1.25rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    transition: padding-left 0.2s;
    gap: 2rem;
  }

  .post-item:hover {
    padding-left: 0.5rem;
  }
  .post-item:hover .post-title {
    color: #0fd28c;
  }
  .post-title {
    font-size: 0.9rem;
    color: #ccc;
    transition: color 0.2s;
  }
  .post-date {
    font-family: "Share Tech Mono", monospace;
    font-size: 0.65rem;
    color: #333;
    letter-spacing: 0.1em;
    white-space: nowrap;
  }

  /* ABOUT */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 4rem;
    align-items: start;
  }
  .about-text {
    font-size: 1rem;
    color: #888;
    line-height: 1.8;
    max-width: 560px;
  }
  .about-links {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
