  <!-- WORK -->
  <section class="section" id="work">
    <p class="section-label">Selected work</p>
    <div class="projects-grid">
      <!-- Card 001 -->
      <a
        href="https://github.com/akifzahin/TimeGaitNet"
        target="_blank"
        rel="noopener"
        class="project-card"
      >
        <p class="project-num font-mono">001</p>
        <h3 class="project-title font-display">TimeGaitNet</h3>
        <p class="project-desc">
          Deep learning framework analyzing wearable accelerometer data to
          detect, forecast, and estimate the intensity of Freezing of Gait
          episodes in Parkinson's patients.
        </p>
        <div class="project-tags">
          <span class="tag">Pytorch</span>
          <span class="tag">TensorFlow</span>
          <span class="tag">NumPy</span>
        </div>
      </a>

      <!-- Card 002 -->
      <a
        href="https://github.com/akifzahin/LM-FCIL"
        target="_blank"
        rel="noopener"
        class="project-card"
      >
        <p class="project-num font-mono">002</p>
        <h3 class="project-title font-display">LM-FCIL</h3>
        <p class="project-desc">
          Federated Class Incremental Learning simulation for Handwriting
          Identification using Dynamic Expanding Classifier.
        </p>
        <div class="project-tags">
          <span class="tag">Kotlin</span>
          <span class="tag">TFLite</span>
          <span class="tag">OpenCV</span>
        </div>
      </a>

      <!-- Card 003 -->
      <a
        href="https://github.com/t4niha/NewsLens"
        target="_blank"
        rel="noopener"
        class="project-card"
      >
        <p class="project-num font-mono">003</p>
        <h3 class="project-title font-display">NewsLens</h3>
        <p class="project-desc">
          BERT-Based Detection of Political Bias in News Articles with Suggested
          Readings.
        </p>
        <div class="project-tags">
          <span class="tag">FastAPI</span>
          <span class="tag">NextJS</span>
          <span class="tag">LLMs</span>
        </div>
      </a>
    </div>
  </section>

  <!-- SKILLS -->
  <section class="section" id="skills">
    <p class="section-label">Skills & Stack</p>
    <div class="skills-grid">

      <div class="skill-group">
        <p class="skill-group-title font-mono">Languages</p>
