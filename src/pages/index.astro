        y="130"
        width="40"
        height="40"
        stroke="#0fd28c"
        stroke-width="1"
        fill="none"></rect>
      <circle cx="150" cy="150" r="4" fill="#0fd28c"></circle>
    </svg>
  </section>

  <section class="section" id="work">
