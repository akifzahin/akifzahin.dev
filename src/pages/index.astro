    <p class="section-label">Education</p>
    <div class="timeline">

      <div class="timeline-item">
        <div class="timeline-left">
          <img src="/images/logoNSU.png" alt="North South University" class="timeline-logo" />
          <p class="timeline-date font-mono">Oct 2021 — Dec 2025</p>
        </div>
        <div class="timeline-right">
          <h3 class="timeline-title font-display">BSc in Computer Science</h3>
          <p class="timeline-company accent-purple">North South University, Dhaka</p>
