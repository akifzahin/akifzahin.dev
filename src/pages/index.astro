---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Akif Zahin">
  <!-- HERO -->
  <section class="hero">
    <div class="hero-content">
      <p class="hero-eyebrow font-mono">
        — Python Dev | Deep Learning | Full Stack
      </p>
      <h1 class="hero-name font-display">
        <div class="name-outline">Akif</div>
        <div class="name-glow">Zahin</div>
      </h1>
      <p class="hero-sub">
        Hi I'm <span class="accent-purple">Akif</span>
        <span class="accent-green">Zahin</span>. I build AI-powered apps and
        full-stack tools that solve real problems. Scroll down to see my work,
        or reach out if you want to build something together.
      </p>
      <div class="cta-row">
        <a href="/resume.pdf" class="btn-primary btn-download" download>
          <span class="btn-label">Download Resume</span>
          <span class="btn-icon">
            <svg
              class="icon-default"
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
