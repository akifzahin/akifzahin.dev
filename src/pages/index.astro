      <circle cx="150" cy="150" r="100" stroke="#6b21d4" stroke-width="1"
      ></circle>
      <circle cx="150" cy="150" r="60" stroke="#0fd28c" stroke-width="1"
      ></circle>
      <line
        x1="10"
        y1="150"
        x2="290"
        y2="150"
        stroke="#0fd28c"
        stroke-width="0.5"></line>
      <line
        x1="150"
        y1="10"
        x2="150"
        y2="290"
        stroke="#0fd28c"
        stroke-width="0.5"></line>
      <line
        x1="50"
        y1="50"
        x2="250"
        y2="250"
        stroke="#6b21d4"
        stroke-width="0.5"></line>
