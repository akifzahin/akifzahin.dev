---
// ThemeSwitcher.astro
---

<div class="theme-controls">
  <button
    id="dark-toggle"
    class="theme-btn"
    aria-label="Toggle dark mode"
    title="Toggle dark mode"
  >
    <svg
      id="icon-moon"
      xmlns="http://www.w3.org/2000/svg"
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="3"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
    </svg>
    <svg
      id="icon-sun"
      xmlns="http://www.w3.org/2000/svg"
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="3"
      stroke-linecap="round"
      stroke-linejoin="round"
      style="display:none"
    >
      <circle cx="12" cy="12" r="4"></circle>
      <path
        d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"
      ></path>
    </svg>
  </button>

  <div class="color-picker-wrapper">
    <button
      id="color-trigger"
      class="theme-btn"
      aria-label="Color theme"
      title="Color theme"
    >
      <span class="trigger-swatch">
        <span class="trigger-dot" id="trigger-dot-a"></span>
        <span class="trigger-dot" id="trigger-dot-b"></span>
      </span>
    </button>

    <ul class="color-dropdown" id="color-dropdown" role="listbox">
      <li
        class="dropdown-item active"
        role="option"
        data-primary="#f40bf4"
        data-accent="#0fd28c"
        data-image="/images/city.webp"
        data-name="Cyberpunk"
        data-vanta="none"
      >
        <span class="swatch" style="--a:#f40bf4; --b:#0fd28c"></span>
        <span>Cyberpunk</span>
      </li>
      <li
        class="dropdown-item"
        role="option"
        data-primary="#ffde4d"
        data-accent="#0066ff"
        data-image="/images/cyber.webp"
        data-name="Webcore"
        data-vanta="NET"
      >
        <span class="swatch" style="--a:#ffde4d; --b:#0066ff"></span>
        <span>Webcore</span>
      </li>
      <li
        class="dropdown-item"
        role="option"
        data-primary="#f4f0db"
        data-accent="#E60000"
        data-image="/images/ray.webp"
        data-name="Retro Futurism"
        data-vanta="WAVES"
      >
        <span class="swatch" style="--a:#f4f0db; --b:#E60000"></span>
        <span>Retro Futurism</span>
      </li>
      <li
        class="dropdown-item"
        role="option"
        data-primary="#d3af37"
        data-accent="#6A0DAD"
        data-image="/images/myth.webp"
        data-name="Mythic Fiction"
        data-vanta="FOG"
      >
        <span class="swatch" style="--a:#d3af37; --b:#6A0DAD"></span>
        <span>Mythic Fiction</span>
      </li>
      <li
        class="dropdown-item"
        role="option"
        data-primary="#996bdb"
        data-accent="#74baf2"
        data-image="/images/dream.webp"
        data-name="Dreamcore"
        data-vanta="CELLS"
      >
        <span class="swatch" style="--a:#996bdb; --b:#74baf2"></span>
        <span>Dreamcore</span>
      </li>
      <li
        class="dropdown-item"
        role="option"
        data-primary="#D8C3A5"
        data-accent="#e85d04"
        data-image="/images/cassette.webp"
        data-name="Cassette Futurism"
        data-vanta="TOPOLOGY"
      >
        <span class="swatch" style="--a:#D8C3A5; --b:#e85d04"></span>
        <span>Cassette Futurism</span>
      </li>
      <li
        class="dropdown-item dropdown-item--custom"
        role="option"
        data-primary="#00ffcc"
        data-accent="#ff00aa"
        data-name="Custom"
        data-vanta="NET"
      >
        <span class="swatch" style="--a:#00ffcc; --b:#ff00aa"></span>
        <span>Custom</span>
      </li>
    </ul>

    <!-- Custom color picker panel — shown when Custom theme is active -->
    <div class="custom-color-panel" id="custom-color-panel" aria-hidden="true">
      <div class="custom-color-panel__header">
        <span>Custom Colors</span>
      </div>
      <div class="color-input-row">
        <label>Primary</label>
        <div class="color-input-wrap">
          <button
            type="button"
            class="color-swatch-btn"
            id="custom-primary-swatch"
            aria-label="Edit primary color"></button>
          <span class="color-input-hex" id="custom-primary-hex">#00ffcc</span>
        </div>
      </div>
      <div class="color-input-row">
        <label>Accent</label>
        <div class="color-input-wrap">
          <button
            type="button"
            class="color-swatch-btn"
            id="custom-accent-swatch"
            aria-label="Edit accent color"></button>
          <span class="color-input-hex" id="custom-accent-hex">#ff00aa</span>
        </div>
      </div>
    </div>

    <!-- Custom HSV color picker popover — replaces native <input type="color"> -->
    <div
      class="color-picker-popover"
      id="color-picker-popover"
      aria-hidden="true"
    >
      <div class="cp-sv-area" id="cp-sv-area">
        <div class="cp-sv-white"></div>
        <div class="cp-sv-black"></div>
        <div class="cp-sv-cursor" id="cp-sv-cursor"></div>
      </div>
      <div class="cp-hue-track" id="cp-hue-track">
        <div class="cp-hue-cursor" id="cp-hue-cursor"></div>
      </div>
      <div class="cp-preview-row">
        <span class="cp-preview-swatch" id="cp-preview-swatch"></span>
        <input
          type="text"
          id="cp-hex-input"
          class="cp-hex-input"
          maxlength="7"
          spellcheck="false"
          autocomplete="off"
        />
      </div>
    </div>
  </div>
</div>

<style>
  .color-swatch-btn {
    width: 32px;
    height: 32px;
    border-radius: 6px;
    border: 1px solid rgba(var(--primary-rgb, 15, 210, 140), 0.4);
    cursor: pointer;
    padding: 0;
    box-shadow: 0 0 6px rgba(var(--primary-rgb, 15, 210, 140), 0.3);
    transition:
      transform 0.15s ease,
      box-shadow 0.15s ease;
  }
  .color-swatch-btn:hover {
    transform: scale(1.08);
    box-shadow: 0 0 10px rgba(var(--primary-rgb, 15, 210, 140), 0.6);
  }

  .color-picker-popover {
    position: fixed;
    width: 200px;
    padding: 12px;
    background: var(--bg, rgba(10, 10, 14, 0.96));
    color: inherit;
    border: 1px solid rgba(var(--primary-rgb, 15, 210, 140), 0.35);
    border-radius: 10px;
    box-shadow:
      0 0 20px rgba(var(--primary-rgb, 15, 210, 140), 0.25),
      0 8px 24px rgba(0, 0, 0, 0.5);
    display: none;
    z-index: 200;
  }
  .color-picker-popover.open {
    display: block;
  }

  .cp-sv-area {
    position: relative;
    width: 100%;
    height: 130px;
    border-radius: 6px;
    overflow: hidden;
    cursor: crosshair;
    margin-bottom: 10px;
    touch-action: none;
  }
  .cp-sv-white,
  .cp-sv-black {
    position: absolute;
    inset: 0;
  }
  .cp-sv-white {
    background: linear-gradient(to right, #fff, rgba(255, 255, 255, 0));
  }
  .cp-sv-black {
    background: linear-gradient(to bottom, rgba(0, 0, 0, 0), #000);
  }
  .cp-sv-cursor {
    position: absolute;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 2px solid #fff;
    box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.6);
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .cp-hue-track {
    position: relative;
    width: 100%;
    height: 14px;
    border-radius: 7px;
    margin-bottom: 10px;
    cursor: pointer;
    touch-action: none;
    background: linear-gradient(
      to right,
      #f00 0%,
      #ff0 17%,
      #0f0 33%,
      #0ff 50%,
      #00f 67%,
      #f0f 83%,
      #f00 100%
    );
  }
  .cp-hue-cursor {
    position: absolute;
    top: 50%;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    border: 2px solid #fff;
    box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.6);
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .cp-preview-row {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .cp-preview-swatch {
    width: 24px;
    height: 24px;
    border-radius: 5px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    flex-shrink: 0;
  }
  .cp-hex-input {
    flex: 1;
    min-width: 0;
    background: rgba(var(--primary-rgb, 15, 210, 140), 0.08);
    border: 1px solid rgba(var(--primary-rgb, 15, 210, 140), 0.3);
    border-radius: 5px;
    color: inherit;
    font-family: "Share Tech Mono", monospace;
    font-size: 0.8rem;
    padding: 4px 6px;
    text-transform: uppercase;
  }
  .cp-hex-input:focus {
    outline: none;
    border-color: var(--primary, #0fd28c);
  }
  .custom-color-panel__header {
    color: var(--primary);
  }
  .light .custom-color-panel__header {
    color: var(--accent);
  }
</style>

<script>
  function hexToRgb(hex: string) {
    const cleaned = hex.trim();
    const r = parseInt(cleaned.slice(1, 3), 16);
    const g = parseInt(cleaned.slice(3, 5), 16);
    const b = parseInt(cleaned.slice(5, 7), 16);
    return `${r}, ${g}, ${b}`;
  }

  // ── HSV <-> Hex conversions for the custom picker ──────────────────────
  function hsvToRgb(h: number, s: number, v: number) {
    const c = v * s;
    const x = c * (1 - Math.abs(((h / 60) % 2) - 1));
    const m = v - c;
    let r = 0,
      g = 0,
      b = 0;
    if (h < 60) [r, g, b] = [c, x, 0];
    else if (h < 120) [r, g, b] = [x, c, 0];
    else if (h < 180) [r, g, b] = [0, c, x];
    else if (h < 240) [r, g, b] = [0, x, c];
    else if (h < 300) [r, g, b] = [x, 0, c];
    else [r, g, b] = [c, 0, x];
    return {
      r: Math.round((r + m) * 255),
      g: Math.round((g + m) * 255),
      b: Math.round((b + m) * 255),
    };
  }

  function rgbToHex(r: number, g: number, b: number) {
    return (
      "#" +
      [r, g, b]
        .map((v) => Math.max(0, Math.min(255, v)).toString(16).padStart(2, "0"))
        .join("")
    );
  }

  function hsvToHex(h: number, s: number, v: number) {
    const { r, g, b } = hsvToRgb(h, s, v);
    return rgbToHex(r, g, b);
  }

  function hexToHsv(hex: string) {
    const cleaned = hex.trim().replace("#", "");
    const r = parseInt(cleaned.slice(0, 2), 16) / 255;
    const g = parseInt(cleaned.slice(2, 4), 16) / 255;
    const b = parseInt(cleaned.slice(4, 6), 16) / 255;
    const max = Math.max(r, g, b);
    const min = Math.min(r, g, b);
    const d = max - min;
    let h = 0;
    if (d !== 0) {
      if (max === r) h = ((g - b) / d) % 6;
      else if (max === g) h = (b - r) / d + 2;
      else h = (r - g) / d + 4;
      h *= 60;
      if (h < 0) h += 360;
    }
    const s = max === 0 ? 0 : d / max;
    const v = max;
    return { h, s, v };
  }

  function applyTheme(primary: string, accent: string, image?: string) {
    const p = primary.trim();
    const a = accent.trim();
    const root = document.documentElement;
    root.style.setProperty("--primary", p);
    root.style.setProperty("--accent", a);
    root.style.setProperty("--primary-rgb", hexToRgb(p));
    root.style.setProperty("--accent-rgb", hexToRgb(a));
    root.style.setProperty("--primary-dim", `rgba(${hexToRgb(p)}, 0.1)`);
    root.style.setProperty("--primary-glow", `rgba(${hexToRgb(p)}, 0.4)`);
    root.style.setProperty("--accent-dim", `rgba(${hexToRgb(a)}, 0.1)`);
    root.style.setProperty("--accent-glow", `rgba(${hexToRgb(a)}, 0.4)`);
    if (image) root.style.setProperty("--hero-image", `url('${image}')`);
  }

  function dispatchThemeChange(name: string, primary: string, accent: string) {
    document.dispatchEvent(
      new CustomEvent("theme-change", {
        detail: { name, primary: primary.trim(), accent: accent.trim() },
      }),
    );
  }

  function savePrefs(
    primary: string,
    accent: string,
    dark: boolean,
    name: string,
    image?: string,
  ) {
    localStorage.setItem("theme-primary", primary.trim());
    localStorage.setItem("theme-accent", accent.trim());
    localStorage.setItem("theme-dark", String(dark));
    localStorage.setItem("theme-name", name);
    if (image) localStorage.setItem("theme-image", image);
  }

  function syncIcons(isDark: boolean) {
    const moon = document.getElementById("icon-moon");
    const sun = document.getElementById("icon-sun");
    if (moon) moon.style.display = isDark ? "" : "none";
    if (sun) sun.style.display = isDark ? "none" : "";
  }

  function syncTrigger(primary: string, accent: string) {
    const dotA = document.getElementById("trigger-dot-a");
    const dotB = document.getElementById("trigger-dot-b");
    const p = primary.trim();
    const a = accent.trim();
    if (dotA) {
      dotA.style.background = p;
      dotA.style.boxShadow = `0 0 5px ${p}`;
    }
    if (dotB) {
      dotB.style.background = a;
      dotB.style.boxShadow = `0 0 5px ${a}`;
    }
  }

  function syncCustomPickers(primary: string, accent: string) {
    const pSwatch = document.getElementById("custom-primary-swatch");
    const aSwatch = document.getElementById("custom-accent-swatch");
    const pHex = document.getElementById("custom-primary-hex");
    const aHex = document.getElementById("custom-accent-hex");
    const p = primary.trim();
    const a = accent.trim();
    if (pSwatch) pSwatch.style.background = p;
    if (aSwatch) aSwatch.style.background = a;
    if (pHex) pHex.textContent = p;
    if (aHex) aHex.textContent = a;
    // Also sync the Custom item's swatch in the dropdown
    const customItem = document.querySelector<HTMLElement>(
      '[data-name="Custom"]',
    );
    if (customItem) {
      const swatch = customItem.querySelector<HTMLElement>(".swatch");
      if (swatch) {
        swatch.style.setProperty("--a", p);
        swatch.style.setProperty("--b", a);
      }
      customItem.dataset.primary = p;
      customItem.dataset.accent = a;
    }
  }

  function closeCustomPanel() {
    const panel = document.getElementById("custom-color-panel");
    if (!panel) return;
    panel.classList.remove("open");
    panel.setAttribute("aria-hidden", "true");
  }

  document.addEventListener("astro:before-swap", (e: Event) => {
    const swap = e as TransitionBeforeSwapEvent;
    const outgoing = document.documentElement;
    const incoming = swap.newDocument.documentElement;

    const props = [
      "--primary",
      "--accent",
      "--primary-rgb",
      "--accent-rgb",
      "--primary-dim",
      "--primary-glow",
      "--accent-dim",
      "--accent-glow",
      "--hero-image",
    ];
    props.forEach((prop) => {
      const val = outgoing.style.getPropertyValue(prop);
      if (val) incoming.style.setProperty(prop, val);
    });

    if (outgoing.classList.contains("light")) {
      incoming.classList.add("light");
    }
  });

  function initThemeSwitcher() {
    const savedPrimary = localStorage.getItem("theme-primary");
    const savedAccent = localStorage.getItem("theme-accent");
    const savedDark = localStorage.getItem("theme-dark");
    const savedImage = localStorage.getItem("theme-image");

    // FIX: this must be mutable — it gets reassigned whenever a new theme
    // is picked, so the dark-toggle (and anything else that reads it later)
    // always dispatches the currently-active theme name instead of whatever
    // was saved at page-load time.
    let savedName = localStorage.getItem("theme-name") ?? "Cyberpunk";

    const initPrimary = savedPrimary ?? "#0fd28c";
    const initAccent = savedAccent ?? "#f40bf4";

    if (savedPrimary && savedAccent) {
      applyTheme(initPrimary, initAccent, savedImage ?? undefined);
    }
    if (savedDark === "false") document.documentElement.classList.add("light");

    const darkToggle = document.getElementById("dark-toggle");
    const colorTrigger = document.getElementById("color-trigger");
    const dropdown = document.getElementById("color-dropdown");
    if (!darkToggle || !colorTrigger || !dropdown) return;

    const items = dropdown.querySelectorAll<HTMLElement>(".dropdown-item");

    // Mark active item based on saved theme name (more reliable than color matching)
    items.forEach((item) => {
      item.classList.toggle("active", item.dataset.name === savedName);
    });

    // Custom picker state — seeded here, kept in sync with the swatch buttons
    let customPrimaryHex =
      localStorage.getItem("custom-primary") ?? initPrimary;
    let customAccentHex = localStorage.getItem("custom-accent") ?? initAccent;
    let cpTarget: "primary" | "accent" | null = null;
    let cpH = 0,
      cpS = 1,
      cpV = 1;

    // If Custom was saved, seed pickers and show panel
    if (savedName === "Custom") {
      syncCustomPickers(customPrimaryHex, customAccentHex);
    }

    let isDark = savedDark !== "false";
    document.documentElement.classList.toggle("light", !isDark);
    syncIcons(isDark);
    syncTrigger(initPrimary, initAccent);

    darkToggle.addEventListener("click", () => {
      isDark = !isDark;
      document.documentElement.classList.toggle("light", !isDark);
      syncIcons(isDark);
      const primary =
        document.documentElement.style.getPropertyValue("--primary") ||
        "#0fd28c";
      const accent =
        document.documentElement.style.getPropertyValue("--accent") ||
        "#f40bf4";
      const image = localStorage.getItem("theme-image") ?? undefined;
      savePrefs(primary, accent, isDark, savedName, image);
      syncTrigger(primary, accent);
      dispatchThemeChange(savedName, primary, accent); // remounts Vanta with new bg
    });

    colorTrigger.addEventListener("click", (e) => {
      e.stopPropagation();
      dropdown.classList.toggle("open");
      // Close custom panel + popover if dropdown closes
      if (!dropdown.classList.contains("open")) {
        closeCustomPanel();
        closeColorPopover();
      }
    });

    document.addEventListener("click", (e) => {
      const panel = document.getElementById("custom-color-panel");
      if (
        !dropdown.contains(e.target as Node) &&
        !colorTrigger.contains(e.target as Node) &&
        !panel?.contains(e.target as Node)
      ) {
        dropdown.classList.remove("open");
        closeCustomPanel();
      }

      const popoverEl = document.getElementById("color-picker-popover");
      const clickedSwatch =
        (e.target as HTMLElement)?.id === "custom-primary-swatch" ||
        (e.target as HTMLElement)?.id === "custom-accent-swatch";
      if (
        popoverEl &&
        !popoverEl.contains(e.target as Node) &&
        !clickedSwatch
      ) {
        closeColorPopover();
      }
    });

    items.forEach((item) => {
      item.addEventListener("click", () => {
        const isCustom = item.dataset.name === "Custom";

        if (isCustom) {
          // Mark active, open picker panel — don't close dropdown
          items.forEach((i) => i.classList.remove("active"));
          item.classList.add("active");
          openCustomPanel();
          return;
        }

        // Regular theme
        closeCustomPanel();
        closeColorPopover();
        dropdown.classList.remove("open");

        const { primary, accent, image, name } = item.dataset as {
          primary: string;
          accent: string;
          image: string;
          name: string;
        };

        const hero = document.querySelector(".hero");
        hero?.classList.add("theme-switching");

        setTimeout(() => {
          applyTheme(primary, accent, image);
          dispatchThemeChange(name, primary, accent);
          hero?.classList.remove("theme-switching");
        }, 400);

        items.forEach((i) => i.classList.remove("active"));
        item.classList.add("active");
        savePrefs(primary, accent, isDark, name, image);
        syncTrigger(primary, accent);
        savedName = name; // FIX: keep in-memory name current for dark-toggle
      });
    });

    function openCustomPanel() {
      const panel = document.getElementById("custom-color-panel");
      if (!panel) return;
      panel.classList.add("open");
      panel.setAttribute("aria-hidden", "false");
      const savedP =
        localStorage.getItem("custom-primary") ??
        localStorage.getItem("theme-primary") ??
        "#00ffcc";
      const savedA =
        localStorage.getItem("custom-accent") ??
        localStorage.getItem("theme-accent") ??
        "#ff00aa";
      customPrimaryHex = savedP;
      customAccentHex = savedA;
      syncCustomPickers(savedP, savedA);
    }

    // ── Custom HSV color picker popover ─────────────────────────────────
    const popover = document.getElementById("color-picker-popover");
    const svArea = document.getElementById("cp-sv-area");
    const svCursor = document.getElementById("cp-sv-cursor");
    const hueTrack = document.getElementById("cp-hue-track");
    const hueCursor = document.getElementById("cp-hue-cursor");
    const cpPreview = document.getElementById("cp-preview-swatch");
    const hexInput = document.getElementById(
      "cp-hex-input",
    ) as HTMLInputElement | null;
    const primarySwatchBtn = document.getElementById("custom-primary-swatch");
    const accentSwatchBtn = document.getElementById("custom-accent-swatch");

    function updateCpUI() {
      const hex = hsvToHex(cpH, cpS, cpV);
      if (svArea) svArea.style.backgroundColor = hsvToHex(cpH, 1, 1);
      if (svCursor) {
        svCursor.style.left = `${cpS * 100}%`;
        svCursor.style.top = `${(1 - cpV) * 100}%`;
      }
      if (hueCursor) hueCursor.style.left = `${(cpH / 360) * 100}%`;
      if (cpPreview) cpPreview.style.background = hex;
      if (hexInput && document.activeElement !== hexInput) hexInput.value = hex;
      return hex;
    }

    function closeColorPopover() {
      if (!popover) return;
      popover.classList.remove("open");
      popover.setAttribute("aria-hidden", "true");
      cpTarget = null;
    }

    function openColorPopover(
      target: "primary" | "accent",
      anchor: HTMLElement,
    ) {
      if (!popover) return;
      cpTarget = target;
      const seedHex = target === "primary" ? customPrimaryHex : customAccentHex;
      const { h, s, v } = hexToHsv(seedHex);
      cpH = h;
      cpS = s;
      cpV = v;
      updateCpUI();
      const rect = anchor.getBoundingClientRect();
      popover.style.top = `${rect.bottom + 8}px`;
      popover.style.left = `${rect.left}px`;
      popover.classList.add("open");
      popover.setAttribute("aria-hidden", "false");
    }

    function commitCpColor() {
      const hex = updateCpUI();
      if (cpTarget === "primary") customPrimaryHex = hex;
      else if (cpTarget === "accent") customAccentHex = hex;
      applyCustomColors();
    }

    function applyCustomColors() {
      syncCustomPickers(customPrimaryHex, customAccentHex);
      applyTheme(customPrimaryHex, customAccentHex);
      dispatchThemeChange("Custom", customPrimaryHex, customAccentHex);
      syncTrigger(customPrimaryHex, customAccentHex);
      savedName = "Custom"; // FIX: keep in-memory name current for dark-toggle
      localStorage.setItem("custom-primary", customPrimaryHex);
      localStorage.setItem("custom-accent", customAccentHex);
      savePrefs(customPrimaryHex, customAccentHex, isDark, "Custom");
    }

    primarySwatchBtn?.addEventListener("click", (e) => {
      e.stopPropagation();
      openColorPopover("primary", primarySwatchBtn);
    });
    accentSwatchBtn?.addEventListener("click", (e) => {
      e.stopPropagation();
      openColorPopover("accent", accentSwatchBtn);
    });

    function handleSvPointer(e: PointerEvent) {
      if (!svArea) return;
      const rect = svArea.getBoundingClientRect();
      const x = Math.min(Math.max(e.clientX - rect.left, 0), rect.width);
      const y = Math.min(Math.max(e.clientY - rect.top, 0), rect.height);
      cpS = rect.width === 0 ? 0 : x / rect.width;
      cpV = rect.height === 0 ? 1 : 1 - y / rect.height;
      commitCpColor();
    }

    function handleHuePointer(e: PointerEvent) {
      if (!hueTrack) return;
      const rect = hueTrack.getBoundingClientRect();
      const x = Math.min(Math.max(e.clientX - rect.left, 0), rect.width);
      cpH = rect.width === 0 ? 0 : (x / rect.width) * 360;
      commitCpColor();
    }

    let svDragging = false;
    let hueDragging = false;

    svArea?.addEventListener("pointerdown", (e) => {
      svDragging = true;
      (e.currentTarget as HTMLElement).setPointerCapture(e.pointerId);
      handleSvPointer(e);
    });
    svArea?.addEventListener("pointermove", (e) => {
      if (svDragging) handleSvPointer(e);
    });
    svArea?.addEventListener("pointerup", () => {
      svDragging = false;
    });
    svArea?.addEventListener("pointercancel", () => {
      svDragging = false;
    });

    hueTrack?.addEventListener("pointerdown", (e) => {
      hueDragging = true;
      (e.currentTarget as HTMLElement).setPointerCapture(e.pointerId);
      handleHuePointer(e);
    });
    hueTrack?.addEventListener("pointermove", (e) => {
      if (hueDragging) handleHuePointer(e);
    });
    hueTrack?.addEventListener("pointerup", () => {
      hueDragging = false;
    });
    hueTrack?.addEventListener("pointercancel", () => {
      hueDragging = false;
    });

    hexInput?.addEventListener("change", () => {
      const val = hexInput.value.trim();
      if (/^#?[0-9a-fA-F]{6}$/.test(val)) {
        const hex = val.startsWith("#") ? val : `#${val}`;
        const { h, s, v } = hexToHsv(hex);
        cpH = h;
        cpS = s;
        cpV = v;
        commitCpColor();
      } else {
        updateCpUI(); // revert to last valid value
      }
    });
  }

  document.addEventListener("astro:page-load", initThemeSwitcher);
</script>
