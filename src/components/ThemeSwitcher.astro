---
// ThemeSwitcher.astro
// Drop this anywhere in your nav layout, e.g. beside the nav-links
---

<div class="theme-controls">
  <!-- Dark / Light toggle -->
  <button
    id="dark-toggle"
    class="theme-btn"
    aria-label="Toggle dark mode"
    title="Toggle dark mode"
  >
    <span class="icon-dark">◑</span>
  </button>

  <!-- Color preset dropdown -->
  <div class="color-picker-wrapper">
    <button
      id="color-trigger"
      class="theme-btn"
      aria-label="Color theme"
      title="Color theme"
    >
      <span class="icon-palette">◈</span>
    </button>
    <ul class="color-dropdown" id="color-dropdown" role="listbox">
      <!-- 1. Default — neon green + pink -->
      <li
        class="dropdown-item active"
        role="option"
        data-primary="#0fd28c"
        data-accent="#f40bf4"
        data-name="Default"
      >
        <span class="swatch" style="--a: #0fd28c; --b: #f40bf4"></span>
        <span>Default</span>
      </li>

      <!-- 2. Atompunk — crisp white + bold crimson red -->
      <li
        class="dropdown-item"
        role="option"
        data-primary="#ffffff"
        data-accent="#e11d48"
        data-name="Atompunk"
      >
        <span class="swatch" style="--a: #ffffff; --b: #e11d48"></span>
        <span>Atompunk</span>
      </li>

      <!-- 3. Cassette Futurism — dark industrial matte black + hazard yellow -->
      <li
        class="dropdown-item"
        role="option"
        data-primary="#111827"
        data-accent="#facc15"
        data-name="Cassette Futurism"
      >
        <span class="swatch" style="--a: #111827; --b: #facc15"></span>
        <span>Cassette Futurism</span>
      </li>

      <!-- 4. Biopunk — sterile deep navy + glowing electric cyan -->
      <li
        class="dropdown-item"
        role="option"
        data-primary="#0f172a"
        data-accent="#06b6d4"
        data-name="Biopunk"
      >
        <span class="swatch" style="--a: #0f172a; --b: #06b6d4"></span>
        <span>Biopunk</span>
      </li>

      <!-- 5. Steampunk — warm antique brass + deep leather sepia -->
      <li
        class="dropdown-item"
        role="option"
        data-primary="#d97706"
        data-accent="#451a03"
        data-name="Steampunk"
      >
        <span class="swatch" style="--a: #d97706; --b: #451a03"></span>
        <span>Steampunk</span>
      </li>

      <!-- 6. Solar Flare — gold + electric blue -->
      <li
        class="dropdown-item"
        role="option"
        data-primary="#ffd000"
        data-accent="#0066ff"
        data-name="Solar Flare"
      >
        <span class="swatch" style="--a: #ffd000; --b: #0066ff"></span>
        <span>Solar Flare</span>
      </li>
    </ul>
  </div>
</div>




<script>
  // ── Helpers ───────────────────────────────────────────────────────────────
  function hexToRgb(hex) {
    const r = parseInt(hex.slice(1, 3), 16);
    const g = parseInt(hex.slice(3, 5), 16);
    const b = parseInt(hex.slice(5, 7), 16);
    return `${r}, ${g}, ${b}`;
  }

  function applyTheme(primary, accent) {
    const root = document.documentElement;
    root.style.setProperty("--primary", primary);
    root.style.setProperty("--accent", accent);
    root.style.setProperty("--primary-rgb", hexToRgb(primary));
    root.style.setProperty("--accent-rgb", hexToRgb(accent));

    // Update glow/dim variants so existing CSS still works
    root.style.setProperty("--primary-dim", `rgba(${hexToRgb(primary)}, 0.1)`);
    root.style.setProperty("--primary-glow", `rgba(${hexToRgb(primary)}, 0.4)`);
    root.style.setProperty("--accent-dim", `rgba(${hexToRgb(accent)}, 0.1)`);
    root.style.setProperty("--accent-glow", `rgba(${hexToRgb(accent)}, 0.4)`);
  }

  function savePrefs(primary, accent, dark) {
    localStorage.setItem("theme-primary", primary);
    localStorage.setItem("theme-accent", accent);
    localStorage.setItem("theme-dark", dark);
  }

  // ── Init from saved prefs ─────────────────────────────────────────────────
  const savedPrimary = localStorage.getItem("theme-primary");
  const savedAccent = localStorage.getItem("theme-accent");
  const savedDark = localStorage.getItem("theme-dark");

  if (savedPrimary && savedAccent) applyTheme(savedPrimary, savedAccent);
  if (savedDark === "false") document.documentElement.classList.add("light");

  // ── DOM refs ──────────────────────────────────────────────────────────────
  const darkToggle = document.getElementById("dark-toggle");
  const colorTrigger = document.getElementById("color-trigger");
  const dropdown = document.getElementById("color-dropdown");
  const items = dropdown.querySelectorAll(".dropdown-item");

  // Mark active item from storage
  if (savedPrimary) {
    items.forEach((item) => {
      item.classList.toggle("active", item.dataset.primary === savedPrimary);
    });
  }

  // ── Dark mode toggle ──────────────────────────────────────────────────────
  let isDark = savedDark !== "false";

  darkToggle.addEventListener("click", () => {
    isDark = !isDark;
    document.documentElement.classList.toggle("light", !isDark);
    const primary =
      document.documentElement.style.getPropertyValue("--primary") || "#0fd28c";
    const accent =
      document.documentElement.style.getPropertyValue("--accent") || "#f40bf4";
    savePrefs(primary, accent, isDark);
  });

  // ── Color dropdown ────────────────────────────────────────────────────────
  colorTrigger.addEventListener("click", (e) => {
    e.stopPropagation();
    dropdown.classList.toggle("open");
  });

  document.addEventListener("click", () => dropdown.classList.remove("open"));

  items.forEach((item) => {
    item.addEventListener("click", () => {
      const { primary, accent } = item.dataset;
      applyTheme(primary, accent);
      items.forEach((i) => i.classList.remove("active"));
      item.classList.add("active");
      savePrefs(primary, accent, isDark);
      dropdown.classList.remove("open");
    });
  });
</script>
