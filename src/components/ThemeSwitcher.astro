---
// ThemeSwitcher.astro
---

<div class="theme-controls">
  <button
    id="dark-toggle"
    class="theme-btn"
    aria-label="Toggle dark mode"
    title="Toggle dark mode"
  >
    <svg
      id="icon-moon"
      xmlns="http://www.w3.org/2000/svg"
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
    </svg>
    <svg
      id="icon-sun"
      xmlns="http://www.w3.org/2000/svg"
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      style="display:none"
    >
      <circle cx="12" cy="12" r="4"></circle>
      <path
        d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"
      ></path>
    </svg>
  </button>

  <div class="color-picker-wrapper">
    <button
      id="color-trigger"
      class="theme-btn"
      aria-label="Color theme"
      title="Color theme"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <circle cx="12" cy="12" r="10"></circle>
        <path
          d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
        ></path>
        <path d="M2 12h20"></path>
      </svg>
    </button>

    <ul class="color-dropdown" id="color-dropdown" role="listbox">
      <li
        class="dropdown-item active"
        role="option"
        data-primary="#0fd28c"
        data-accent="#f40bf4"
        data-image="/images/city.png"
        data-name="Cyberpunk"
      >
        <span class="swatch" style="--a:#0fd28c; --b:#f40bf4"></span>
        <span>Cyberpunk</span>
      </li>
      <li
        class="dropdown-item"
        role="option"
        data-primary="#ffde4d"
        data-accent="#0066ff"
        data-image="/images/volt.jpg"
        data-name="Voltpunk"
      >
        <span class="swatch" style="--a:#ffde4d; --b:#0066ff"></span>
        <span>Voltpunk</span>
      </li>
      <li
        class="dropdown-item"
        role="option"
        data-primary="#f4f0db"
        data-accent="#E60000"
        data-image="/images/ray.jpg"
        data-name="Raypunk"
      >
        <span class="swatch" style="--a:#f4f0db; --b:#E60000"></span>
        <span>Raypunk</span>
      </li>
      <li
        class="dropdown-item"
        role="option"
        data-primary="#d3af37 "
        data-accent="#6A0DAD"
        data-image="/images/myth.jpg"
        data-name="Mythpunk"
      >
        <span class="swatch" style="--a:#d3af37; --b:#6A0DAD"></span>
        <span>Mythpunk</span>
      </li>
      <li
        class="dropdown-item"
        role="option"
        data-primary="#74baf2"
        data-accent="#996bdb"
        data-image="/images/dream.jpg"
        data-name="Dreamcore"
      >
        <span class="swatch" style="--a:#74baf2; --b:#996bdb"></span>
        <span>Dreamcore</span>
      </li>
      <li
        class="dropdown-item"
        role="option"
        data-primary="#D8C3A5"
        data-accent="#F97316"
        data-image="/images/cassette.jpg"
        data-name="Cassette Futurism"
      >
        <span class="swatch" style="--a:#D8C3A5; --b:#F97316"></span>
        <span>Cassette Futurism</span>
      </li>
    </ul>
  </div>
</div>

<script>
  function hexToRgb(hex: string) {
    const r = parseInt(hex.slice(1, 3), 16);
    const g = parseInt(hex.slice(3, 5), 16);
    const b = parseInt(hex.slice(5, 7), 16);
    return `${r}, ${g}, ${b}`;
  }

  function applyTheme(primary: string, accent: string, image?: string) {
    const root = document.documentElement;
    root.style.setProperty("--primary", primary);
    root.style.setProperty("--accent", accent);
    root.style.setProperty("--primary-rgb", hexToRgb(primary));
    root.style.setProperty("--accent-rgb", hexToRgb(accent));
    root.style.setProperty("--primary-dim", `rgba(${hexToRgb(primary)}, 0.1)`);
    root.style.setProperty("--primary-glow", `rgba(${hexToRgb(primary)}, 0.4)`);
    root.style.setProperty("--accent-dim", `rgba(${hexToRgb(accent)}, 0.1)`);
    root.style.setProperty("--accent-glow", `rgba(${hexToRgb(accent)}, 0.4)`);
    if (image) root.style.setProperty("--hero-image", `url('${image}')`);
  }

  function savePrefs(
    primary: string,
    accent: string,
    dark: boolean,
    image?: string,
  ) {
    localStorage.setItem("theme-primary", primary);
    localStorage.setItem("theme-accent", accent);
    localStorage.setItem("theme-dark", String(dark));
    if (image) localStorage.setItem("theme-image", image);
  }

  function syncIcons(isDark: boolean) {
    const moon = document.getElementById("icon-moon");
    const sun = document.getElementById("icon-sun");
    if (moon) moon.style.display = isDark ? "" : "none";
    if (sun) sun.style.display = isDark ? "none" : "";
  }

  document.addEventListener("astro:before-swap", (e: Event) => {
    const swap = e as TransitionBeforeSwapEvent;
    const outgoing = document.documentElement;
    const incoming = swap.newDocument.documentElement;

    const props = [
      "--primary",
      "--accent",
      "--primary-rgb",
      "--accent-rgb",
      "--primary-dim",
      "--primary-glow",
      "--accent-dim",
      "--accent-glow",
      "--hero-image",
    ];
    props.forEach((prop) => {
      const val = outgoing.style.getPropertyValue(prop);
      if (val) incoming.style.setProperty(prop, val);
    });

    if (outgoing.classList.contains("light")) {
      incoming.classList.add("light");
    }
  });

  function initThemeSwitcher() {
    const savedPrimary = localStorage.getItem("theme-primary");
    const savedAccent = localStorage.getItem("theme-accent");
    const savedDark = localStorage.getItem("theme-dark");
    const savedImage = localStorage.getItem("theme-image");

    if (savedPrimary && savedAccent) {
      applyTheme(savedPrimary, savedAccent, savedImage ?? undefined);
    }
    if (savedDark === "false") document.documentElement.classList.add("light");

    const darkToggle = document.getElementById("dark-toggle");
    const colorTrigger = document.getElementById("color-trigger");
    const dropdown = document.getElementById("color-dropdown");
    if (!darkToggle || !colorTrigger || !dropdown) return;

    const items = dropdown.querySelectorAll<HTMLElement>(".dropdown-item");

    if (savedPrimary) {
      items.forEach((item) => {
        item.classList.toggle("active", item.dataset.primary === savedPrimary);
      });
    }

    let isDark = savedDark !== "false";
    syncIcons(isDark);

    darkToggle.addEventListener("click", () => {
      isDark = !isDark;
      document.documentElement.classList.toggle("light", !isDark);
      syncIcons(isDark);
      const primary =
        document.documentElement.style.getPropertyValue("--primary") ||
        "#0fd28c";
      const accent =
        document.documentElement.style.getPropertyValue("--accent") ||
        "#f40bf4";
      const image = localStorage.getItem("theme-image") ?? undefined;
      savePrefs(primary, accent, isDark, image);
    });

    colorTrigger.addEventListener("click", (e) => {
      e.stopPropagation();
      dropdown.classList.toggle("open");
    });

    document.addEventListener("click", () => dropdown.classList.remove("open"));

    items.forEach((item) => {
      item.addEventListener("click", () => {
        const { primary, accent, image } = item.dataset as {
          primary: string;
          accent: string;
          image: string;
        };
        applyTheme(primary, accent, image);
        items.forEach((i) => i.classList.remove("active"));
        item.classList.add("active");
        savePrefs(primary, accent, isDark, image);
        dropdown.classList.remove("open");
      });
    });
    // close drawer when clicking outside on mobile
    document.addEventListener("click", (e) => {
      if (
        !dropdown.contains(e.target as Node) &&
        !colorTrigger.contains(e.target as Node)
      ) {
        dropdown.classList.remove("open");
      }
    });
  }

  document.addEventListener("astro:page-load", initThemeSwitcher);
</script>
