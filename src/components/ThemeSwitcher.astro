---
// ThemeSwitcher.astro
---

<div class="theme-controls">
  <button id="dark-toggle" class="theme-btn" aria-label="Toggle dark mode" title="Toggle dark mode">
    <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
    </svg>
    <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="display:none">
      <circle cx="12" cy="12" r="4"/>
      <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
    </svg>
  </button>

  <div class="color-picker-wrapper">
    <button id="color-trigger" class="theme-btn" aria-label="Color theme" title="Color theme">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/>
        <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
        <path d="M2 12h20"/>
      </svg>
    </button>

    <ul class="color-dropdown" id="color-dropdown" role="listbox">
      <li class="dropdown-item active" role="option" data-primary="#0fd28c" data-accent="#f40bf4" data-image="/images/city.png" data-name="Cyberpunk">
        <span class="swatch" style="--a:#0fd28c; --b:#f40bf4"></span>
        <span>Cyberpunk</span>
      </li>
      <li class="dropdown-item" role="option" data-primary="#ffd000" data-accent="#0066ff" data-image="/images/volt.jpg" data-name="Voltpunk">
        <span class="swatch" style="--a:#ffd000; --b:#0066ff"></span>
        <span>Voltpunk</span>
      </li>
      <li class="dropdown-item" role="option" data-primary="#f4f0db" data-accent="#E60000" data-image="/images/ray.jpg" data-name="Raypunk">
        <span class="swatch" style="--a:#f4f0db; --b:#E60000"></span>
        <span>Raypunk</span>
      </li>
      <li class="dropdown-item" role="option" data-primary="#6A0DAD" data-accent="#FFD700" data-image="/images/myth.jpg" data-name="Mythpunk">
        <span class="swatch" style="--a:#6A0DAD; --b:#FFD700"></span>
        <span>Mythpunk</span>
      </li>
      <li class="dropdown-item" role="option" data-primary="#74baf2" data-accent="#996bdb" data-image="/images/dream.jpg" data-name="Dreamcore">
        <span class="swatch" style="--a:#74baf2; --b:#996bdb"></span>
        <span>Dreamcore</span>
      </li>
      <li class="dropdown-item" role="option" data-primary="#D8C3A5" data-accent="#F97316" data-image="/images/cassette.jpg" data-name="Cassette Futurism">
        <span class="swatch" style="--a:#D8C3A5; --b:#F97316"></span>
        <span>Cassette Futurism</span>
      </li>
    </ul>
  </div>
</div>

<script>
  // ── Helpers ─────────────────────────────────────────────────────────────────
  function hexToRgb(hex: string) {
    const r = parseInt(hex.slice(1, 3), 16);
    const g = parseInt(hex.slice(3, 5), 16);
    const b = parseInt(hex.slice(5, 7), 16);
    return `${r}, ${g}, ${b}`;
  }

  function applyTheme(primary: string, accent: string) {
    const root = document.documentElement;
    root.style.setProperty("--primary", primary);
    root.style.setProperty("--accent", accent);
    root.style.setProperty("--primary-rgb", hexToRgb(primary));
    root.style.setProperty("--accent-rgb", hexToRgb(accent));
    root.style.setProperty("--primary-dim", `rgba(${hexToRgb(primary)}, 0.1)`);
    root.style.setProperty("--primary-glow", `rgba(${hexToRgb(primary)}, 0.4)`);
    root.style.setProperty("--accent-dim", `rgba(${hexToRgb(accent)}, 0.1)`);
    root.style.setProperty("--accent-glow", `rgba(${hexToRgb(accent)}, 0.4)`);
  }

  function savePrefs(primary: string, accent: string, dark: boolean) {
    localStorage.setItem("theme-primary", primary);
    localStorage.setItem("theme-accent", accent);
    localStorage.setItem("theme-dark", String(dark));
  }

  // ── Preserve theme across SPA navigations ────────────────────────────────────
  // astro:before-swap fires before the old DOM is replaced with the new page.
  // We copy our inline style properties from the outgoing <html> onto the
  // incoming <html> so the new page never flashes unstyled.
  document.addEventListener("astro:before-swap", (e: Event) => {
    const swap = e as TransitionBeforeSwapEvent;
    const outgoing = document.documentElement;
    const incoming = swap.newDocument.documentElement;

    const props = [
      "--primary", "--accent",
      "--primary-rgb", "--accent-rgb",
      "--primary-dim", "--primary-glow",
      "--accent-dim", "--accent-glow",
    ];
    props.forEach((prop) => {
      const val = outgoing.style.getPropertyValue(prop);
      if (val) incoming.style.setProperty(prop, val);
    });

    // Carry over light-mode class
    if (outgoing.classList.contains("light")) {
      incoming.classList.add("light");
    }
  });

  // ── Init / re-init on every page load ────────────────────────────────────────
  // Runs on hard load AND after every SPA navigation, re-attaching listeners
  // to the freshly rendered ThemeSwitcher markup in the nav.
  function initThemeSwitcher() {
    const savedPrimary = localStorage.getItem("theme-primary");
    const savedAccent = localStorage.getItem("theme-accent");
    const savedDark = localStorage.getItem("theme-dark");

    // Apply saved colours (the before-swap handler already did this for
    // navigations, but this covers hard loads and keeps the switcher in sync).
    if (savedPrimary && savedAccent) applyTheme(savedPrimary, savedAccent);
    if (savedDark === "false") document.documentElement.classList.add("light");

    const darkToggle = document.getElementById("dark-toggle");
    const colorTrigger = document.getElementById("color-trigger");
    const dropdown = document.getElementById("color-dropdown");
    if (!darkToggle || !colorTrigger || !dropdown) return;

    const items = dropdown.querySelectorAll<HTMLElement>(".dropdown-item");

    // Mark active item from storage
    if (savedPrimary) {
      items.forEach((item) => {
        item.classList.toggle("active", item.dataset.primary === savedPrimary);
      });
    }

    // Dark mode toggle
    let isDark = savedDark !== "false";

    darkToggle.addEventListener("click", () => {
      isDark = !isDark;
      document.documentElement.classList.toggle("light", !isDark);
      const primary =
        document.documentElement.style.getPropertyValue("--primary") || "#0fd28c";
      const accent =
        document.documentElement.style.getPropertyValue("--accent") || "#f40bf4";
      savePrefs(primary, accent, isDark);
    });

    // Color dropdown open/close
    colorTrigger.addEventListener("click", (e) => {
      e.stopPropagation();
      dropdown.classList.toggle("open");
    });

    document.addEventListener("click", () => dropdown.classList.remove("open"));

    // Color preset selection
    items.forEach((item) => {
      item.addEventListener("click", () => {
        const { primary, accent } = item.dataset as { primary: string; accent: string };
        applyTheme(primary, accent);
        items.forEach((i) => i.classList.remove("active"));
        item.classList.add("active");
        savePrefs(primary, accent, isDark);
        dropdown.classList.remove("open");
      });
    });
  }

  document.addEventListener("astro:page-load", initThemeSwitcher);
</script>