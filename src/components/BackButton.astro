---
const currentPath = Astro.url.pathname;
const isPost = currentPath.startsWith("/blog/") && currentPath !== "/blog/";
const isAdminEdit =
  currentPath.startsWith("/admin/edit/") ||
  currentPath.startsWith("/admin/new");

let backHref = "/";
if (isPost) backHref = "/blog";
else if (isAdminEdit) backHref = "/admin";
---

<a id="back-button" href="/" aria-label="Back">
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="24"
    height="24"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="lucide lucide-square-arrow-left-icon lucide-square-arrow-left"
    ><rect width="18" height="18" x="3" y="3" rx="2"></rect><path
      d="m12 8-4 4 4 4"></path><path d="M16 12H8"></path></svg
  >
</a>

<script>
  document.addEventListener("astro:page-load", () => {
    const btn = document.getElementById(
      "back-button",
    ) as HTMLAnchorElement | null;
    if (!btn) return;

    btn.addEventListener("click", (e) => {
      // If there's real browser history to go back to, use it —
      // otherwise fall back to the href already on the element.
      if (
        window.history.length > 1 &&
        document.referrer.includes(window.location.origin)
      ) {
        e.preventDefault();
        window.history.back();
      }
      // else: let the default href navigation happen (fallback for direct links/new tabs)
    });
  });
</script>
