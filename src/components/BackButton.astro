---
const currentPath = Astro.url.pathname;
const isPost = currentPath.startsWith("/blog/") && currentPath !== "/blog/";
const backHref = isPost ? "/blog" : "/";
---

<a id="back-button" href={backHref} aria-label="Back">
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="24"
    height="24"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="lucide lucide-square-arrow-left-icon lucide-square-arrow-left"
    ><rect width="18" height="18" x="3" y="3" rx="2"></rect><path
      d="m12 8-4 4 4 4"></path><path d="M16 12H8"></path></svg
  >
</a>
