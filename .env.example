# Turso (SQLite) database
# Get these from: turso db show blogs-akifzahin --url
#                 turso db tokens create blogs-akifzahin
TURSO_DB_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Session / auth
# Generate with: openssl rand -base64 32
SESSION_SECRET=your-session-secret
ADMIN_PASSWORD=your-admin-password

# Vercel Blob (image storage)
# Get these from Vercel dashboard -> Storage -> Blob
BLOB_STORE_ID=your-blob-store-id
BLOB_READ_WRITE_TOKEN=your-blob-read-write-token
